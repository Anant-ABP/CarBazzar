@model IReadOnlyList<CarBazzar.Models.Cars.CarCard>
@{
    ViewData["Title"] = "Wishlist";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: #f5f0eb;
        color: #1a1a1a;
    }

    .wl-page {
        min-height: 100vh;
        background: #f5f0eb;
        padding: 40px 0 72px;
    }

    .wl-container {
        max-width: 1060px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .wl-page-title {
        font-size: 32px;
        font-weight: 900;
        color: #1a1008;
        letter-spacing: -0.6px;
        margin-bottom: 6px;
    }

    .wl-page-sub {
        font-size: 14px;
        color: #999;
        margin-bottom: 36px;
    }

    /* Empty state */
    .wl-empty {
        background: #fff;
        border-radius: 16px;
        padding: 56px 32px;
        text-align: center;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .wl-empty-icon {
        font-size: 48px;
        color: #e0d8d0;
        margin-bottom: 16px;
    }

    .wl-empty-text {
        font-size: 15px;
        color: #aaa;
        margin-bottom: 20px;
    }

    .wl-browse-btn {
        display: inline-block;
        background: #f07500;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        padding: 12px 28px;
        border-radius: 10px;
        text-decoration: none;
        transition: background 0.22s, transform 0.15s;
    }

        .wl-browse-btn:hover {
            background: #d86a00;
            transform: translateY(-1px);
            color: #fff;
        }

    /* Car Grid */
    .wl-car-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .wl-car-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        position: relative;
        transition: transform 0.28s ease, box-shadow 0.28s ease;
    }

        .wl-car-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.12);
        }

    .wl-car-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
    }

    .wl-car-card:hover .wl-car-img {
        transform: scale(1.04);
    }

    .wl-car-body {
        padding: 16px 18px 20px;
    }

    .wl-car-title {
        font-size: 15px;
        font-weight: 700;
        color: #1a1008;
        margin-bottom: 4px;
    }

    .wl-car-price {
        font-size: 18px;
        font-weight: 800;
        color: #f07500;
        margin-bottom: 10px;
    }

    .wl-car-meta {
        font-size: 12px;
        color: #888;
    }

    /* Heart button */
    .wl-heart-form {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
    }

    .wl-heart-btn {
        width: 34px;
        height: 34px;
        background: #f07500;
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 16px;
        color: #fff;
        box-shadow: 0 2px 8px rgba(240,117,0,0.35);
        transition: transform 0.2s, background 0.2s;
    }

        .wl-heart-btn:hover {
            transform: scale(1.15);
            background: #d86a00;
        }

    .wl-car-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    /* Footer */
    .wl-footer {
        background: #1a1a1a;
        padding: 56px 0 28px;
        margin-top: 72px;
    }

    .wl-footer-inner {
        max-width: 1060px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .wl-footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 48px;
        margin-bottom: 40px;
    }

    .wl-footer-brand {
        display: flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 14px;
    }

    .wl-footer-brand-icon {
        width: 36px;
        height: 36px;
        background: #f07500;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .wl-footer-brand-icon svg {
            width: 20px;
            height: 20px;
            fill: #fff;
        }

    .wl-footer-brand-name {
        font-size: 18px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.3px;
    }

    .wl-footer-desc {
        font-size: 13.5px;
        color: #888;
        line-height: 1.7;
        max-width: 280px;
    }

    .wl-footer-col-title {
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 16px;
    }

    .wl-footer-links {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .wl-footer-links a {
            color: #888;
            text-decoration: none;
            font-size: 13.5px;
            transition: color 0.2s;
        }

            .wl-footer-links a:hover {
                color: #f07500;
            }

    .wl-footer-contact {
        display: flex;
        flex-direction: column;
        gap: 10px;
        font-size: 13.5px;
        color: #888;
        line-height: 1.6;
    }

    .wl-footer-bottom {
        border-top: 1px solid #2e2e2e;
        padding-top: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .wl-footer-copy {
        font-size: 13px;
        color: #555;
    }

    .wl-footer-socials {
        display: flex;
        gap: 12px;
    }

    .wl-social-btn {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        background: #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        text-decoration: none;
    }

        .wl-social-btn:hover {
            background: #f07500;
        }

        .wl-social-btn svg {
            width: 16px;
            height: 16px;
            fill: #aaa;
        }

        .wl-social-btn:hover svg {
            fill: #fff;
        }

    @@media (max-width: 900px) {
        .wl-car-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .wl-footer-grid {
            grid-template-columns: 1fr;
            gap: 28px;
        }
    }

    @@media (max-width: 500px) {
        .wl-car-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="wl-page">
    <div class="wl-container">

        <h1 class="wl-page-title">My Wishlist</h1>
        <p class="wl-page-sub">Cars you've saved for later</p>

        @if (Model.Count == 0)
        {
            <div class="wl-empty">
                <div class="wl-empty-icon">♡</div>
                <div class="wl-empty-text">No saved cars yet. Start browsing and save your favourites.</div>
                <a class="wl-browse-btn" asp-controller="Cars" asp-action="Browse">Browse Cars</a>
            </div>
        }
        else
        {
            <div class="wl-car-grid">
                @foreach (var car in Model)
                {
                    <div class="wl-car-card">
                        <form class="wl-heart-form" method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@car.Id">
                            <button type="submit" class="wl-heart-btn" aria-label="Remove from wishlist">♥</button>
                        </form>
                        <a class="wl-car-link" asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id">
                            <img class="wl-car-img" src="@car.ImageUrl" alt="@car.Title" />
                            <div class="wl-car-body">
                                <div class="wl-car-title">@car.Title</div>
                                <div class="wl-car-price">@car.Price</div>
                                <div class="wl-car-meta">@car.Specs</div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

    </div>
</div>

@section Scripts {
}