@model IReadOnlyList<CarBazzar.Models.Cars.CarCard>
@{
    ViewData["Title"] = "Wishlist";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
            <div>
                <h2 class="mb-1">Wishlist</h2>
                <div class="text-muted">Cars you’ve saved for later.</div>
            </div>
            <a class="btn btn-outline-warning" asp-controller="Cars" asp-action="Browse">Browse more</a>
        </div>

        @if (Model.Count == 0)
        {
            <div class="bg-white rounded-4 p-4 shadow-sm border">
                <div class="text-muted">No saved cars yet.</div>
            </div>
        }
        else
        {
            <div class="car-grid">
                @foreach (var car in Model)
                {
                    <div class="car-card">
                        <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@car.Id">
                            <button type="submit"
                                    class="wishlist-btn is-active"
                                    aria-label="Remove from wishlist"
                                    aria-pressed="true">
                                ♥
                            </button>
                        </form>
                        <a class="car-card-link text-decoration-none" asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id">
                            <img src="@car.ImageUrl" alt="@car.Title" />
                            <div class="car-info">
                                <h6 class="text-dark">@car.Title</h6>
                                <p class="mb-2">@car.Specs</p>
                                <span>@car.Price</span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</section>

