@model CarBazzar.Models.Auth.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Admin Login";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="~/css/account-adminlogin.css" rel="stylesheet">

<section class="cb-shell">
    <div class="cb-card">

        <div class="cb-left">
            <div>
                <h2 class="cb-left-headline">Find your next ride.</h2>
                <p class="cb-left-sub">Buy and sell verified used cars with confidence on CarBazaar.</p>
                <div class="cb-car-wrap">
                    <img src="https://cdn.motor1.com/images/mgl/j1QVR/s1/mclaren-600lt-mclaren-orange.jpg" alt="Car" />
                </div>
                </br>
                <p class="cb-left-footnote">Secure logins, verified sellers, and transparent deals on every car.</p>
            </div>
        </div>

        <div class="cb-right">

            <div class="cb-brand">
                <div class="cb-brand-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z" />
                    </svg>
                </div>
                <span class="cb-brand-name">CarBazaar</span>
            </div>

            <div class="cb-tabs">
                <a class="cb-tab" asp-controller="Account" asp-action="Login">User Login</a>
                <a class="cb-tab active" asp-controller="Account" asp-action="AdminLogin">Admin Login</a>
            </div>

            <h1 class="cb-form-title">Admin Login</h1>
            <p class="cb-form-sub">Welcome, Admin. Sign in to manage the platform.</p>

            <form asp-action="AdminLogin" asp-controller="Account" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="cb-field">
                    <label class="cb-label">Admin Email</label>
                    <input asp-for="Email" class="cb-input" placeholder="Enter your email" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="cb-field">
                    <label class="cb-label">Password</label>
                    <div class="cb-pw-wrap">
                        <input asp-for="Password" id="cb-pw" class="cb-input" placeholder="Enter your password" autocomplete="current-password" />
                        <button type="button" class="cb-eye-btn" id="cb-eye-toggle" aria-label="Toggle password">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="cb-remember">
                    <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                    <label for="rememberMe">Remember me</label>
                </div>

                <button type="submit" class="cb-btn">Log in</button>
            </form>
        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('cb-eye-toggle').addEventListener('click', function () {
            var pw = document.getElementById('cb-pw');
            pw.type = pw.type === 'text' ? 'password' : 'text';
        });
    </script>
}