@model CarBazzar.Models.Auth.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Admin Login";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        font-family: 'Inter', sans-serif;
        background: #edeae4 !important;
        margin: 0;
        padding: 0;
    }

    .container, .container-fluid,
    main, [role="main"] {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
        background: transparent !important;
        box-shadow: none !important;
        border-radius: 0 !important;
    }

    .cb-shell {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 32px 16px;
        background: #edeae4;
    }

    .cb-card {
        display: flex;
        width: 100%;
        max-width: 900px;
        min-height: 540px;
        background: #ffffff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 4px 32px rgba(0,0,0,0.09);
        animation: cardIn 0.5s cubic-bezier(.22,.68,0,1.2) both;
    }

    @@keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(20px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .cb-left {
        flex: 0 0 43%;
        background: #fdf6ec;
        padding: 44px 36px 36px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .cb-left-headline {
        font-family: 'Inter', sans-serif;
        font-size: 24px;
        font-weight: 800;
        color: #1a1008;
        line-height: 1.25;
        margin-bottom: 10px;
        letter-spacing: -0.3px;
    }

    .cb-left-sub {
        font-size: 13.5px;
        color: #7a6a55;
        line-height: 1.65;
        margin-bottom: 22px;
    }

    .cb-car-wrap {
        width: 100%;
        border-radius: 10px;
        overflow: hidden;
    }

        .cb-car-wrap img {
            width: 100%;
            height: 195px;
            object-fit: cover;
            display: block;
            transition: transform 0.45s ease;
        }

        .cb-car-wrap:hover img {
            transform: scale(1.03);
        }

    .cb-left-footnote {
        font-size: 12.5px;
        color: #a08060;
        margin-top: 18px;
        line-height: 1.65;
    }

    .cb-right {
        flex: 1;
        padding: 44px 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: #ffffff;
    }

    .cb-brand {
        display: flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 24px;
    }

    .cb-brand-icon {
        width: 34px;
        height: 34px;
        background: #f07500;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: transform 0.3s ease;
    }

        .cb-brand-icon:hover {
            transform: rotate(-8deg) scale(1.1);
        }

        .cb-brand-icon svg {
            width: 19px;
            height: 19px;
            fill: #fff;
        }

    .cb-brand-name {
        font-size: 17px;
        font-weight: 700;
        color: #f07500;
        letter-spacing: -0.2px;
    }

    .cb-tabs {
        display: flex;
        background: #f2f2f2;
        border-radius: 10px;
        padding: 4px;
        gap: 3px;
        margin-bottom: 28px;
    }

    .cb-tab {
        flex: 1;
        padding: 9px 0;
        text-align: center;
        font-size: 13.5px;
        font-weight: 600;
        color: #999;
        border-radius: 7px;
        border: none;
        background: transparent;
        text-decoration: none;
        display: block;
        transition: all 0.22s ease;
        cursor: pointer;
    }

        .cb-tab:hover {
            color: #555;
        }

        .cb-tab.active {
            background: #fff;
            color: #1a1a1a;
            box-shadow: 0 1px 5px rgba(0,0,0,0.11);
        }

    .cb-form-title {
        font-family: 'Inter', sans-serif;
        font-size: 24px;
        font-weight: 800;
        color: #1a1008;
        margin-bottom: 5px;
        letter-spacing: -0.3px;
    }

    .cb-form-sub {
        font-size: 13px;
        color: #999;
        margin-bottom: 24px;
        line-height: 1.55;
    }

    .cb-field {
        margin-bottom: 16px;
    }

    .cb-label {
        display: block;
        font-size: 12.5px;
        font-weight: 600;
        color: #3a3a3a;
        margin-bottom: 6px;
    }

    .cb-input {
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid #e8e8e8;
        border-radius: 9px;
        font-family: 'Inter', sans-serif;
        font-size: 13.5px;
        color: #1a1a1a;
        background: #fff;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

        .cb-input::placeholder {
            color: #c5c5c5;
        }

        .cb-input:focus {
            border-color: #f07500;
            box-shadow: 0 0 0 3px rgba(240,117,0,0.11);
        }

    .cb-pw-wrap {
        position: relative;
    }

        .cb-pw-wrap .cb-input {
            padding-right: 44px;
        }

    .cb-eye-btn {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #bbb;
        display: flex;
        align-items: center;
        padding: 4px;
        transition: color 0.2s;
    }

        .cb-eye-btn:hover {
            color: #f07500;
        }

        .cb-eye-btn svg {
            width: 17px;
            height: 17px;
        }

    .cb-remember {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
    }

        .cb-remember input[type="checkbox"] {
            width: 15px;
            height: 15px;
            accent-color: #f07500;
            cursor: pointer;
        }

        .cb-remember label {
            font-size: 13px;
            color: #555;
            cursor: pointer;
        }

    .cb-btn {
        width: 100%;
        padding: 13px;
        background: #f07500;
        color: #fff;
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        letter-spacing: 0.1px;
        margin-bottom: 18px;
        transition: background 0.22s ease, transform 0.15s ease, box-shadow 0.22s ease;
    }

        .cb-btn:hover {
            background: #d86a00;
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(240,117,0,0.30);
        }

        .cb-btn:active {
            transform: translateY(0);
            box-shadow: none;
        }

    .text-danger {
        font-size: 11.5px;
        color: #e03e3e;
        margin-top: 3px;
        display: block;
    }

    @@media (max-width: 620px) {
        .cb-left {
            display: none;
        }

        .cb-right {
            padding: 32px 22px;
        }
    }
</style>

<section class="cb-shell">
    <div class="cb-card">

        <div class="cb-left">
            <div>
                <h2 class="cb-left-headline">Find your next ride.</h2>
                <p class="cb-left-sub">Buy and sell verified used cars with confidence on CarBazaar.</p>
                <div class="cb-car-wrap">
                    <img src="https://cdn.motor1.com/images/mgl/j1QVR/s1/mclaren-600lt-mclaren-orange.jpg" alt="Car" />
                </div>
            </div>
            <p class="cb-left-footnote">Secure logins, verified sellers, and transparent deals on every car.</p>
        </div>

        <div class="cb-right">

            <div class="cb-brand">
                <div class="cb-brand-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z" />
                    </svg>
                </div>
                <span class="cb-brand-name">CarBazaar</span>
            </div>

            <div class="cb-tabs">
                <a class="cb-tab" asp-controller="Account" asp-action="Login">User Login</a>
                <a class="cb-tab active" asp-controller="Account" asp-action="AdminLogin">Admin Login</a>
            </div>

            <h1 class="cb-form-title">Admin Login</h1>
            <p class="cb-form-sub">Welcome, Admin. Sign in to manage the platform.</p>

            <form asp-action="AdminLogin" asp-controller="Account" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="cb-field">
                    <label class="cb-label">Admin Email</label>
                    <input asp-for="Email" class="cb-input" placeholder="Enter your email" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="cb-field">
                    <label class="cb-label">Password</label>
                    <div class="cb-pw-wrap">
                        <input asp-for="Password" id="cb-pw" class="cb-input" placeholder="Enter your password" autocomplete="current-password" />
                        <button type="button" class="cb-eye-btn" id="cb-eye-toggle" aria-label="Toggle password">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="cb-remember">
                    <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                    <label for="rememberMe">Remember me</label>
                </div>

                <button type="submit" class="cb-btn">Log in</button>
            </form>
        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('cb-eye-toggle').addEventListener('click', function () {
            var pw = document.getElementById('cb-pw');
            pw.type = pw.type === 'text' ? 'password' : 'text';
        });
    </script>
}