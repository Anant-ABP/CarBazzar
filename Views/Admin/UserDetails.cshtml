@model CarBazzar.Models.Entity.ApplicationUser
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "User Details";
}

<section class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white border-bottom p-4">
            <h4 class="mb-0">User Details</h4>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-4 text-center">
                    <div class="avatar-circle avatar-bg-orange mb-3" style="width: 100px; height: 100px; font-size: 3rem; margin: 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: white; background-color: #f07500;">
                        @(!string.IsNullOrEmpty(Model.FirstName) ? Model.FirstName[0].ToString() : "U")
                    </div>
                    <h5 class="fw-bold">@Model.FirstName @Model.LastName</h5>
                    <p class="text-muted">@Model.Email</p>
                    
                    @if (Model.IsHidden)
                    {
                        <span class="badge bg-danger mb-3">HIDDEN</span>
                    }
                    else
                    {
                        <span class="badge bg-success mb-3">ACTIVE</span>
                    }
                </div>
                <div class="col-md-8">
                    <h5 class="border-bottom pb-2 mb-3">Contact & Log Information</h5>
                    <div class="mb-3">
                        <label class="fw-bold text-muted small">Phone Number</label>
                        <div>@(Model.PhoneNumber ?? "Not provided")</div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold text-muted small">Location</label>
                        <div>@(Model.Location ?? "Not provided")</div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold text-muted small">Address</label>
                        <div>@(Model.Address ?? "Not provided")</div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold text-muted small">Date Joined</label>
                        <div>@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <a asp-action="Users" class="btn btn-outline-secondary">Back to Users</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
