@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users Management";
}

<style>
    .stat-card { border-radius: 16px; border: none; box-shadow: 0 2px 12px rgba(0,0,0,.06); transition: box-shadow .2s; }
    .stat-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.10); }
    .section-card { border-radius: 18px; border: none; box-shadow: 0 4px 20px rgba(0,0,0,.06); }
    .table thead tr th {
        font-size: 11px; color: #a29a8d; text-transform: uppercase;
        letter-spacing: .12em; font-weight: 600; border-bottom: 1px solid #f0ece7; padding-bottom: 10px;
    }
    .table tbody tr td { font-size: 13px; color: #40352c; padding: 13px 12px; vertical-align: middle; }
    .table tbody tr { border-bottom: 1px solid #f7f4f1; }
    .table tbody tr:last-child { border-bottom: none; }
    .role-badge, .status-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600;
    }
    .badge-admin    { background: #f4e5ff; color: #8e3ecc; }
    .badge-user     { background: #e9f2ff; color: #276fd0; }
    .badge-active   { background: #e6f7ef; color: #138a4a; }
    .badge-suspended{ background: #fdeae9; color: #d9534f; }
    .action-btn {
        width: 28px; height: 28px; border-radius: 8px; border: none;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; background: transparent; transition: background .15s;
    }
    .action-btn:hover { background: #f5f0eb; }
    .form-select {
        border-radius: 999px !important; border-color: #e5ded3 !important;
        font-size: 12px !important; padding: 6px 14px !important;
        box-shadow: none !important;
    }
    .form-select:focus { border-color: #f97316 !important; box-shadow: 0 0 0 3px rgba(249,115,22,.12) !important; }
    .avatar-circle {
        width: 34px; height: 34px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700; color: #fff; flex-shrink: 0;
    }
</style>

<section>
    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card" style="background:#ffffff;">
                <div class="card-body p-3">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                        <div style="font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:#7b8ad9;font-weight:600;">Total Users</div>
                        <div style="width:36px;height:36px;border-radius:10px;background:#e0e6ff;display:flex;align-items:center;justify-content:center;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f6ef7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                    </div>
                    <div style="font-size:24px;font-weight:800;color:#142055;line-height:1;">12,847</div>
                    <div style="font-size:12px;color:#9ca4d5;margin-top:4px;">Total platform members</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card" style="background:#ffffff;">
                <div class="card-body p-3">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                        <div style="font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:#6ba88a;font-weight:600;">Active Users</div>
                        <div style="width:36px;height:36px;border-radius:10px;background:#e0f6ea;display:flex;align-items:center;justify-content:center;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                            </svg>
                        </div>
                    </div>
                    <div style="font-size:24px;font-weight:800;color:#074b33;line-height:1;">9,234</div>
                    <div style="font-size:12px;color:#7cae91;margin-top:4px;">Currently active users</div>
                </div>
            </div>
        </div>
    </div>

