@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users Management";
}
<link rel="stylesheet" href="~/css/admin-users.css" />

<section>
    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card stat-card-bg">
                <div class="card-body p-3">
                    <div class="stat-card-header">
                        <div class="stat-label">Total Users</div>
                        <div class="stat-icon-box">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f6ef7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                    </div>
                    <div class="stat-number">12,847</div>
                    <div class="stat-description">Total platform members</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card stat-card-bg">
                <div class="card-body p-3">
                    <div class="stat-card-header">
                        <div class="stat-label">Active Users</div>
                        <div class="stat-icon-box">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                            </svg>
                        </div>
                    </div>
                    <div class="stat-number">9,234</div>
                    <div class="stat-description">Currently active users</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card section-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 section-title">All Users</h5>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm">
                        <option>All Roles</option>
                        <option>Admin</option>
                        <option>User</option>
                    </select>
                    <select class="form-select form-select-sm">
                        <option>All Status</option>
                        <option>Active</option>
                        <option>Suspended</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Total Listings</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    
                        <tr>
                            <td>
                                <div class="user-info-flex">
                                    <div class="avatar-circle avatar-bg-orange">MS</div>
                                    <div>
                                        <div class="fw-semibold">Mital Singh</div>
                                        <div class="text-muted user-email-text">mitals@email.com</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="role-badge badge-user"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#276fd0" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>User</span></td>
                            <td class="listing-count-bold">24</td>
                            <td><span class="status-badge badge-active"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#138a4a" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Active</span></td>
                            <td class="text-end">
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="user-info-flex">
                                    <div class="avatar-circle avatar-bg-cyan">MA</div>
                                    <div>
                                        <div class="fw-semibold">Mohammad Ali</div>
                                        <div class="text-muted user-email-text">mohhammada@email.com</div>
