                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
