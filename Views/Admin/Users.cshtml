@model IEnumerable<CarBazzar.Models.Entity.ApplicationUser>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users Management";
}
<link rel="stylesheet" href="~/css/admin-users.css" />

<section>
    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card stat-card stat-card-bg">
                <div class="card-body p-3">
                    <div class="stat-card-header">
                        <div class="stat-label">Total Users</div>
                        <div class="stat-icon-box">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f6ef7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                    </div>
                    <div class="stat-number">@Model.Count()</div>
                    <div class="stat-description">Total platform members</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card section-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 section-title">All Users</h5>
            </div>

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="user-info-flex">
                                        <div class="avatar-circle avatar-bg-orange">@(!string.IsNullOrEmpty(user.FirstName) ? user.FirstName[0].ToString() : "U")</div>
                                        <div>
                                            <div class="fw-semibold">@user.FirstName @user.LastName</div>
                                            <div class="text-muted user-email-text">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="role-badge badge-user"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#276fd0" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>User</span></td>
                                <td>
                                    @if(user.IsHidden) {
                                        <span class="status-badge bg-danger text-white border-0 px-2 py-1 rounded small">Hidden</span>
                                    } else {
                                        <span class="status-badge badge-active"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#138a4a" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Active</span>
                                    }
                                </td>
                                <td class="text-end d-flex justify-content-end gap-2">
                                    <a href="@Url.Action("UserDetails", "Admin", new { id = user.Id })" class="action-btn text-primary" title="View">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </a>
                                    <form asp-action="HideUser" asp-route-id="@user.Id" method="post" style="display:inline;">
                                        <button type="submit" class="action-btn text-warning" title="@(user.IsHidden ? "Unhide" : "Hide")">
                                            @if (user.IsHidden) {
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                            } else {
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                            }
                                        </button>
                                    </form>
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <button type="submit" class="action-btn text-danger border-0 bg-transparent" title="Delete">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center text-muted mt-4">
                    <p>No users found.</p>
                </div>
            }
        </div>
    </div>
</section>
