@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users Management";
}

<section>
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card border-0" style="border-radius:16px;background:#f4f6ff;">
                <div class="card-body">
                    <div style="font-size:12px;text-transform:uppercase;letter-spacing:.14em;color:#7b8ad9;font-weight:600;margin-bottom:6px;">Total Users</div>
                    <div style="font-size:24px;font-weight:800;color:#142055;">12,847</div>
                    <div style="font-size:12px;color:#9ca4d5;">Total platform members</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0" style="border-radius:16px;background:#f3fbf7;">
                <div class="card-body">
                    <div style="font-size:12px;text-transform:uppercase;letter-spacing:.14em;color:#6ba88a;font-weight:600;margin-bottom:6px;">Active Users</div>
                    <div style="font-size:24px;font-weight:800;color:#074b33;">9,234</div>
                    <div style="font-size:12px;color:#7cae91;">Total active users</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0" style="border-radius:18px;box-shadow:0 10px 34px rgba(0,0,0,.06);">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0" style="font-size:15px;font-weight:700;color:#1a1008;">All Users</h5>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" style="border-radius:999px;border-color:#e5ded3;font-size:12px;padding:6px 12px;">
                        <option>All Roles</option>
                        <option>Admin</option>
                        <option>User</option>
                    </select>
                    <select class="form-select form-select-sm" style="border-radius:999px;border-color:#e5ded3;font-size:12px;padding:6px 12px;">
                        <option>All Status</option>
                        <option>Active</option>
                        <option>Suspended</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr style="font-size:12px;color:#a29a8d;text-transform:uppercase;letter-spacing:.12em;">
                            <th scope="col">User</th>
                            <th scope="col">Role</th>
                            <th scope="col">Total Listings</th>
                            <th scope="col">Status</th>
                            <th scope="col" class="text-end">Actions</th>
