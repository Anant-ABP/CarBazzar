@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard Overview";
}

<section>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0" style="border-radius:16px;background:#fffaf3;box-shadow:0 6px 24px rgba(0,0,0,.04);">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div style="font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:#b39b7c;font-weight:600;margin-bottom:6px;">Total Listings</div>
                        <div style="font-size:26px;font-weight:800;color:#1a1008;">2,847</div>
                    </div>
                    <div style="width:40px;height:40px;border-radius:12px;background:#fff1e0;display:flex;align-items:center;justify-content:center;font-size:20px;">🚗</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0" style="border-radius:16px;background:#f3fbf7;box-shadow:0 6px 24px rgba(0,0,0,.04);">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div style="font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:#6ba88a;font-weight:600;margin-bottom:6px;">Active Listings</div>
                        <div style="font-size:26px;font-weight:800;color:#074b33;">2,156</div>
                    </div>
                    <div style="width:40px;height:40px;border-radius:12px;background:#e0f6ea;display:flex;align-items:center;justify-content:center;font-size:20px;">✅</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0" style="border-radius:16px;background:#f4f6ff;box-shadow:0 6px 24px rgba(0,0,0,.04);">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div style="font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:#7b8ad9;font-weight:600;margin-bottom:6px;">Total Users</div>
                        <div style="font-size:26px;font-weight:800;color:#142055;">18,329</div>
                    </div>
                    <div style="width:40px;height:40px;border-radius:12px;background:#e0e6ff;display:flex;align-items:center;justify-content:center;font-size:20px;">👥</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0" style="border-radius:18px;box-shadow:0 10px 34px rgba(0,0,0,.06);">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <h5 class="mb-0" style="font-size:15px;font-weight:700;color:#1a1008;">Recent Listings</h5>
                </div>
                <button class="btn btn-sm" style="background:#fff5eb;color:#f97316;font-weight:600;border-radius:999px;padding:6px 16px;border:none;">View All</button>
            </div>
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr style="font-size:12px;color:#a29a8d;text-transform:uppercase;letter-spacing:.12em;">
                            <th scope="col">Car</th>
                            <th scope="col">Seller</th>
                            <th scope="col">Date</th>
                           
                        </tr>
                    </thead>
                    <tbody style="font-size:13px;color:#40352c;">
                        <tr>
                            <td>
                                <div class="fw-semibold">BMW M4 Competition</div>
                                <div class="text-muted" style="font-size:12px;">2023 • Manual</div>
                            </td>
                            <td>Michael Chen</td>
                            <td>Jan 15, 2025</td>
                        </tr>
                        <tr>
                            <td>
                                <div class="fw-semibold">Mercedes-Benz GLE 450</div>
                                <div class="text-muted" style="font-size:12px;">2024 • Automatic</div>
                            </td>
                            <td>Sarah Johnson</td>
                            <td>Jan 14, 2025</td>
                            
                        </tr>
                        <tr>
                            <td>
                                <div class="fw-semibold">Audi A6 Quattro</div>
                                <div class="text-muted" style="font-size:12px;">2023 • Automatic</div>
                            </td>
                            <td>David Park</td>
                            <td>Jan 13, 2025</td>
                            
                        </tr>
                        <tr>
                            <td>
                                <div class="fw-semibold">Porsche 911 Carrera</div>
                                <div class="text-muted" style="font-size:12px;">2024 • Manual</div>
                            </td>
                            <td>James Wilson</td>
                            <td>Jan 12, 2025</td>
                            
                        </tr>
                        <tr>
                            <td>
                                <div class="fw-semibold">Tesla Model S Plaid</div>
                                <div class="text-muted" style="font-size:12px;">2024 • Automatic</div>
                            </td>
                            <td>Emma Davis</td>
                            <td>Jan 11, 2025</td>
                            
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

