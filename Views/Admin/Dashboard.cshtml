@model IEnumerable<CarBazzar.Models.Entity.Car>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard Overview";
}
<link href="~/css/admin-dashboard.css" rel="stylesheet" />

<section>

    <div class="row g-3 mb-4">
        <!-- Total Listings -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card-new">
                <div class="stat-icon-box stat-icon-box-orange">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2.5"/>
                        <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                        <line x1="12" y1="12" x2="12" y2="16"/>
                        <line x1="10" y1="14" x2="14" y2="14"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-card-label">Total Listings</div>
                    <div class="stat-card-value">@ViewBag.TotalCars</div>
                </div>
            </div>
        </div>

        <!-- Active Contexts (Messages) -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card-new">
                <div class="stat-icon-box stat-icon-box-green">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-card-label">Total Messages</div>
                    <div class="stat-card-value">@ViewBag.TotalMessages</div>
                </div>
            </div>
        </div>

        <!-- Total Users -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card-new">
                <div class="stat-icon-box stat-icon-box-orange">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-card-label">Total Users</div>
                    <div class="stat-card-value">@ViewBag.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Listings Table -->
    <div class="card section-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 recent-listings-title">Recent Listings</h5>
                <a asp-action="Listings" class="btn btn-sm view-all-btn">View All</a>
            </div>

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Car</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var car in Model) {
                            <tr>
                                <td>
                                    <div class="car-info">
                                        <div class="car-image text-center">
                                            <img src="@Url.Action("GetImage", "Cars", new { id = car.Id })" style="width: 30px; height: 30px; object-fit: cover; border-radius: 5px;" onerror="this.style.display='none'" />
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@car.Title</div>
                                            <div class="text-muted car-details">@car.Year • @car.Transmission</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="price">₹@car.Price.ToString("N0")</td>
                                <td><span class="status-badge badge-approved">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#138a4a" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                    Approved
                                </span></td>
                                <td class="date">@car.CreatedAt.ToString("MMM dd")</td>
                                <td class="text-end">
                                    <button class="action-btn del" title="Delete">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</section>