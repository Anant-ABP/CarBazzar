@model IEnumerable<CarBazzar.Models.Entity.Car>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard Overview";
}
<link href="~/css/admin-dashboard.css" rel="stylesheet" />

<section>

    <div class="row g-3 mb-4">
        <!-- Total Listings -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card-new">
                <div>
                    <div class="stat-card-label">Total Listings</div>
                    <div class="stat-card-value">@ViewBag.TotalCars</div>
                    <div style="color: #22c55e; font-size: 11px; font-weight: 500; margin-top: 4px;">Cars on Platform</div>
                </div>
                <div class="stat-icon-box stat-icon-box-orange ms-auto">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2.5"/>
                        <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                        <line x1="12" y1="12" x2="12" y2="16"/>
                        <line x1="10" y1="14" x2="14" y2="14"/>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Active Listings -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card-new">
                <div>
                    <div class="stat-card-label">Active Listings</div>
                    <div class="stat-card-value">@ViewBag.TotalCars</div>
                    <div style="color: #22c55e; font-size: 11px; font-weight: 500; margin-top: 4px;">Available Cars</div>
                </div>
                <div class="stat-icon-box stat-icon-box-green ms-auto" style="background:#f0fdf4; border:1px solid #dcfaf8; border-radius:12px;">
                    <div style="width:24px; height:24px; border-radius:50%; border:2px solid #22c55e; display:flex; align-items:center; justify-content:center;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Users -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card-new">
                <div>
                    <div class="stat-card-label">Total Users</div>
                    <div class="stat-card-value">@ViewBag.TotalUsers</div>
                    <div style="color: #22c55e; font-size: 11px; font-weight: 500; margin-top: 4px;">Platform Users</div>
                </div>
                <div class="stat-icon-box ms-auto" style="background: #eff6ff;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Listings Table -->
    <div class="card section-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 recent-listings-title">Recent Listings</h5>
                <a asp-action="Listings" class="btn btn-sm view-all-btn">View All</a>
            </div>

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>CAR</th>
                            <th>SELLER</th>
                            <th>PRICE</th>
                            <th>STATUS</th>
                            <th>DATE</th>
                            <th class="text-end">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var car in Model) {
                            <tr>
                                <td>
                                    <div class="car-info">
                                        <div class="car-image text-center">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b7aea5" stroke-width="2"><path d="M3 13h18"/><path d="M16 8l-2-4H10L8 8H4v9h16V8h-4z"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="16.5" cy="17.5" r="2.5"/></svg>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@car.Title</div>
                                            <div class="text-muted car-details">@car.Year • @(car.Condition == "Used" ? "old" : "new")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="seller-info">
                                        <div class="avatar-circle" style="background:#e5ded3; color:#1a1008; width:28px; height:28px; font-size:10px;">KR</div>
                                        <span class="fw-medium" style="font-size:12px;">kriss</span>
                                    </div>
                                </td>
                                <td class="price">₹@car.Price.ToString("N0")</td>
                                <td>
                                    <span class="status-badge badge-approved">
                                        Approved
                                    </span>
                                </td>
                                <td class="date">@car.CreatedAt.ToString("d MMM yyyy")</td>
                                <td class="text-end">
                                    <button class="action-btn" title="View" style="border: 1px solid #e5ded3;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#8c8273" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </button>
                                    <button class="action-btn mx-1" title="Edit" style="border: 1px solid #e5ded3;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#8c8273" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <button class="action-btn del" title="Delete" style="border: 1px solid #e5ded3;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</section>