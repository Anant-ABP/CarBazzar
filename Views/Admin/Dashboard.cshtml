@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard Overview";
}

<style>

    .stat-card-new {
        background: #ffffff;
        border-radius: 14px;
        border: none;
        box-shadow: 0 1px 10px rgba(0,0,0,.06);
        padding: 16px 18px;
        transition: box-shadow .2s, transform .2s;
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .stat-card-new:hover {
        box-shadow: 0 4px 18px rgba(0,0,0,.10);
        transform: translateY(-1px);
    }
    .stat-icon-box {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .stat-card-label {
        font-size: 12px;
        color: #a29a8d;
        font-weight: 500;
        margin-bottom: 3px;
    }
    .stat-card-value {
        font-size: 22px;
        font-weight: 800;
        color: #1a1008;
        line-height: 1;
        letter-spacing: -.4px;
    }

    .section-card {
        border-radius: 18px; border: none;
        box-shadow: 0 4px 20px rgba(0,0,0,.06);
        background: #fff;
    }
    .section-card .card-body { padding: 24px; }
    .table thead tr th {
        font-size: 11px; color: #a29a8d;
        text-transform: uppercase; letter-spacing: .12em;
        font-weight: 600; border-bottom: 1px solid #f0ece7; padding-bottom: 10px;
    }
    .table tbody tr td { font-size: 13px; color: #40352c; padding: 13px 12px; vertical-align: middle; }
    .table tbody tr { border-bottom: 1px solid #f7f4f1; }
    .table tbody tr:last-child { border-bottom: none; }
    .table tbody tr:hover { background: #fdfaf8; }
    .avatar-circle {
        width: 32px; height: 32px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; color: #fff;
    }
    .status-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600;
    }
    .badge-approved { background: #e6f7ef; color: #138a4a; }
    .badge-pending  { background: #fff5eb; color: #f97316; }
    .badge-rejected { background: #fdeae9; color: #d9534f; }
    .action-btn {
        width: 28px; height: 28px; border-radius: 8px; border: none;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; background: transparent; transition: background .15s;
    }
    .action-btn:hover { background: #f5f0eb; }
    .action-btn.del:hover { background: #fdeae9; }
</style>

<section>

    <div class="row g-3 mb-4">

    <!-- Total Listings -->
    <div class="col-md-4 col-sm-6">
        <div class="stat-card-new">
            <div class="stat-icon-box" style="background:#fff1e0;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2.5"/>
                    <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                    <line x1="12" y1="12" x2="12" y2="16"/>
                    <line x1="10" y1="14" x2="14" y2="14"/>
