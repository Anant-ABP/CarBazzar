@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Car";
}
<link rel="stylesheet" href="~/css/admin-addlisting.css" />

<section class="add-shell">
    <div class="add-title">Add Car</div>

    <div class="add-grid">
        <div class="add-field">
            <label>Car name</label>
            <input class="add-input" placeholder="eg. BMW" />
        </div>
        <div class="add-field">
            <label>Car Model</label>
            <input class="add-input" placeholder="eg. M3" />
        </div>
        <div class="add-field">
            <label>Year</label>
            <input class="add-input" placeholder="eg. 2023" />
        </div>
        <div class="add-field">
            <label>Price</label>
            <input class="add-input" placeholder="eg. $2000000" />
        </div>
    </div>

    <div class="add-image-row">
        <div class="add-field add-field-margin">
            <label class="label-margin">Add Car Image</label>
        </div>
        <label class="add-upload">
            <div class="large-minus">−</div>
            <strong>Upload Car Image</strong>
            <input type="file" accept="image/*" class="hidden-input" />
        </label>
    </div>

    <div class="add-actions">
        <button class="add-btn primary" type="button">Add Car</button>
        <a class="add-btn secondary d-flex align-items-center justify-content-center text-decoration-none white-text"
           asp-controller="Admin" asp-action="Listings">Cancel</a>
    </div>
</section>

