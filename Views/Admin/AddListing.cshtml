@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Car";
}

<style>
    .add-shell {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 14px 40px rgba(0,0,0,0.10);
        padding: 46px 54px;
        max-width: 980px;
        margin: 28px auto 0;
        min-height: 560px;
    }

    .add-title {
        font-size: 26px;
        font-weight: 800;
        color: #1a1008;
        text-align: center;
        margin-bottom: 40px;
    }

    .add-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px 64px;
        max-width: 720px;
        margin: 0 auto;
    }

    .add-field label {
        display: block;
        font-size: 16px;
        font-weight: 700;
        color: #1a1008;
        margin-bottom: 10px;
    }

    .add-input {
        width: 100%;
        height: 42px;
        padding: 10px 18px;
        border: 1.5px solid #cfc7be;
        border-radius: 999px;
        outline: none;
        font-size: 14px;
        color: #1a1008;
        background: #fff;
    }

    .add-input::placeholder { color: #c3bab0; }

    .add-input:focus {
        border-color: #f59e0b;
        box-shadow: 0 0 0 3px rgba(245,158,11,0.12);
    }

    .add-image-row {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 24px;
        align-items: center;
        max-width: 720px;
        margin: 44px auto 0;
    }

    .add-upload {
        height: 110px;
        border: 1.5px solid #cfc7be;
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #b7aea5;
        gap: 10px;
        background: #fff;
        cursor: pointer;
        user-select: none;
    }

    .add-upload strong {
        font-weight: 700;
        font-size: 13px;
        color: #b7aea5;
    }

    .add-actions {
        display: flex;
        justify-content: center;
        gap: 26px;
        margin-top: 70px;
    }

    .add-btn {
        min-width: 190px;
        height: 46px;
        border-radius: 999px;
        border: none;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: transform .12s ease, opacity .12s ease;
    }

    .add-btn:hover { opacity: .92; transform: translateY(-1px); }

    .add-btn.primary { background: #f59e0b; color: #fff; }
    .add-btn.secondary { background: #f59e0b; color: #fff; opacity: .85; }

    @@media (max-width: 900px) {
        .add-shell { padding: 36px 22px; margin: 18px 12px 0; }
        .add-grid { grid-template-columns: 1fr; gap: 22px; }
        .add-image-row { grid-template-columns: 1fr; }
        .add-actions { flex-direction: column; align-items: center; }
        .add-btn { width: 100%; max-width: 320px; }
    }
</style>

<section class="add-shell">
    <div class="add-title">Add Car</div>

    <div class="add-grid">
        <div class="add-field">
            <label>Car name</label>
            <input class="add-input" placeholder="eg. BMW" />
        </div>
        <div class="add-field">
            <label>Car Model</label>
            <input class="add-input" placeholder="eg. M3" />
        </div>
        <div class="add-field">
            <label>Year</label>
            <input class="add-input" placeholder="eg. 2023" />
        </div>
        <div class="add-field">
            <label>Price</label>
            <input class="add-input" placeholder="eg. $2000000" />
        </div>
    </div>

    <div class="add-image-row">
        <div class="add-field" style="margin:0;">
            <label style="margin:0;">Add Car Image</label>
        </div>
        <label class="add-upload">
            <div style="font-size:28px;line-height:1;">−</div>
            <strong>Upload Car Image</strong>
            <input type="file" accept="image/*" style="display:none;" />
        </label>
    </div>

    <div class="add-actions">
        <button class="add-btn primary" type="button">Add Car</button>
        <a class="add-btn secondary d-flex align-items-center justify-content-center text-decoration-none"
           style="color:#fff;"
           asp-controller="Admin" asp-action="Listings">Cancel</a>
    </div>
</section>

