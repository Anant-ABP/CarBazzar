@model CarBazzar.Models.Cars.SellViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Listing";
}

<section>
    <div class="mb-4">
        <h4 class="fw-bold" style="color: #1a1008; margin-bottom: 2px;">Add New Listing</h4>
        <p style="color: #a29a8d; font-size: 14px; margin-bottom: 0;">Add a vehicle to the CarBazaar inventory.</p>
    </div>

    <div class="card" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.1); max-width: 900px;">
        <div class="card-body" style="padding: 32px;">
            <form asp-action="AddListing" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Car Name (Title)</label>
                        <input asp-for="Title" class="form-control form-control-sm" style="padding: 10px 14px; border-radius: 8px !important;" required placeholder="e.g. 2024 BMW M4" />
                        <span asp-validation-for="Title" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Brand</label>
                        <select asp-for="Brand" class="form-select form-select-sm" style="padding: 10px 14px; border-radius: 8px !important;" required>
                            <option value="">Select Brand</option>
                            <option>Toyota</option>
                            <option>Ford</option>
                            <option>BMW</option>
                            <option>Honda</option>
                            <option>Mercedes-Benz</option>
                            <option>Audi</option>
                            <option>Tesla</option>
                            <option>Porsche</option>
                        </select>
                        <span asp-validation-for="Brand" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Model</label>
                        <input asp-for="Model" class="form-control form-control-sm" style="padding: 10px 14px; border-radius: 8px !important;" required placeholder="e.g. M4 Competition" />
                        <span asp-validation-for="Model" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Price (₹)</label>
                        <input asp-for="Price" type="number" class="form-control form-control-sm" style="padding: 10px 14px; border-radius: 8px !important;" required placeholder="e.g. 850000" />
                        <span asp-validation-for="Price" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Type (New/Old)</label>
                        <select asp-for="Condition" class="form-select form-select-sm" style="padding: 10px 14px; border-radius: 8px !important;" required>
                            <option value="New">New Car</option>
                            <option value="Old">Used/Old Car</option>
                        </select>
                        <span asp-validation-for="Condition" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Year</label>
                        <input asp-for="Year" type="number" class="form-control form-control-sm" style="padding: 10px 14px; border-radius: 8px !important;" required placeholder="2024" />
                        <span asp-validation-for="Year" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Mileage (km)</label>
                        <input asp-for="Mileage" type="number" class="form-control form-control-sm" style="padding: 10px 14px; border-radius: 8px !important;" required placeholder="0" />
                        <span asp-validation-for="Mileage" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Fuel Type</label>
                        <select asp-for="FuelType" class="form-select form-select-sm" style="padding: 10px 14px; border-radius: 8px !important;" required>
                            <option value="Petrol">Petrol</option>
                            <option value="Diesel">Diesel</option>
                            <option value="Electric">Electric</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="CNG">CNG</option>
                        </select>
                        <span asp-validation-for="FuelType" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Transmission</label>
                        <select asp-for="Transmission" class="form-select form-select-sm" style="padding: 10px 14px; border-radius: 8px !important;" required>
                            <option value="Automatic">Automatic</option>
                            <option value="Manual">Manual</option>
                            <option value="PDK">PDK / Dual-Clutch</option>
                            <option value="CVT">CVT</option>
                        </select>
                        <span asp-validation-for="Transmission" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Location</label>
                        <input asp-for="Location" class="form-control form-control-sm" style="padding: 10px 14px; border-radius: 8px !important;" required placeholder="e.g. Mumbai" />
                        <span asp-validation-for="Location" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Vehicle Photo</label>
                        <input asp-for="Image" type="file" class="form-control form-control-sm" style="padding: 10px 14px; border-radius: 8px !important; background: #fff; cursor: pointer;" accept="image/*" required />
                        <span asp-validation-for="Image" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label mb-1" style="font-size: 13px; font-weight: 600; color: #1a1008;">Description</label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="4" style="padding: 10px 14px; border-radius: 8px !important;" required placeholder="Enter a detailed description about the car..."></textarea>
                        <span asp-validation-for="Description" class="text-danger" style="font-size: 12px;"></span>
                    </div>

                    <!-- Admin Note -->
                    <div class="col-12 mt-3">
                        <div style="background: #fff8f3; border: 1px solid #fde8d0; border-radius: 8px; padding: 12px 16px; display: flex; gap: 10px; align-items: flex-start;">
                            <svg style="color: #f97316; flex-shrink: 0; margin-top: 2px;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <div style="font-size: 12px; color: #8a5e3a; line-height: 1.5;">
                                <strong>Admin Post — Active Immediately</strong><br/>
                                A newly posted listing will appear directly in Browse New Cars or Buy Old Car section. A verification email will be sent to your admin address.
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4 pt-3 d-flex justify-content-end gap-3 align-items-center" style="border-top: 1px solid #f0ece7;">
                    <a asp-action="Listings" class="btn btn-light bg-white border text-decoration-none" style="border-radius: 999px; padding: 10px 24px; font-size: 14px; font-weight: 600; color: #1a1008;">Cancel</a>
                    <button type="submit" class="btn" style="border-radius: 999px; padding: 10px 24px; font-size: 14px; font-weight: 600; background: #f97316; color: white;">Add Listing</button>
                </div>
            </form>
        </div>
    </div>
</section>
