@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Listings Management";
}

<link rel="stylesheet" href="~/css/admin-listings.css" />

<section>
    <div class="mb-3 d-flex justify-content-end">
        <a asp-controller="Admin" asp-action="AddListing"
           class="btn d-inline-flex align-items-center gap-2 btn-add-listing">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Listing
        </a>
    </div>

    <div class="card section-card">
        <div class="card-body p-4">

            <!-- Filters -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="search-wrap">
                        <span class="search-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#b39b7c" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        </span>
                        <input class="form-control" placeholder="Search listings..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select">
                        <option>All Status</option>
                        <option>Approved</option>
                        <option>Pending</option>
                        <option>Rejected</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select">
                        <option>All Brands</option>
                        <option>Toyota</option>
                        <option>Honda</option>
                        <option>BMW</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Car</th>
                            <th>Seller</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Date Posted</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/2721-inset12-2024-maserati-mc20.png" class="car-thumbnail" />
                                    <div>
                                        <div class="fw-semibold">Toyota Camry</div>
                                        <div class="text-muted car-description">2022 • Sedan</div>
                                    </div>
                                </div>
                            </td>
                            <td>Ajay Shah</td>
                            <td class="price-text">₹28,50,000</td>
                            <td>
                                <span class="status-badge badge-approved">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#138a4a" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                    Approved
                                </span>
                            </td>
                            <td class="date-text">Mar 15, 2024</td>
                            <td class="text-end">
                                <button class="action-btn" title="View">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                                <button class="action-btn" title="Edit">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                                <button class="action-btn" title="Delete">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" class="car-thumbnail" />
                                    <div>
                                        <div class="fw-semibold">Honda Civic</div>
                                        <div class="text-muted car-description">2023 • Hatchback</div>
                                    </div>
                                </div>
                            </td>
                            <td>Mansi Verma</td>
                            <td class="price-text">₹22,24,900</td>
                            <td>
                                <span class="status-badge badge-pending">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="3"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
                                    Pending
                                </span>
                            </td>
                            <td class="date-text">Mar 14, 2024</td>
                            <td class="text-end">
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" class="car-thumbnail" />
                                    <div>
                                        <div class="fw-semibold">BMW X5</div>
                                        <div class="text-muted car-description">2021 • SUV</div>
                                    </div>
                                </div>
                            </td>
                            <td>Vikram Nair</td>
                            <td class="price-text">₹52,00,000</td>
                            <td>
                                <span class="status-badge badge-rejected">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    Rejected
                                </span>
                            </td>
                            <td class="date-text">Mar 13, 2024</td>
                            <td class="text-end">
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" class="car-thumbnail" />
                                    <div>
                                        <div class="fw-semibold">Mercedes C-Class</div>
                                        <div class="text-muted car-description">2022 • Sedan</div>
                                    </div>
                                </div>
                            </td>
                            <td>Arjun Singh</td>
                            <td class="price-text">₹45,80,000</td>
                            <td>
                                <span class="status-badge badge-approved">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#138a4a" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                    Approved
                                </span>
                            </td>
                            <td class="date-text">Mar 12, 2024</td>
                            <td class="text-end">
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" class="car-thumbnail" />
                                    <div>
                                        <div class="fw-semibold">Audi A4</div>
                                        <div class="text-muted car-description">2023 • Sedan</div>
                                    </div>
                                </div>
                            </td>
                            <td>Rajesh Kumar</td>
                            <td class="price-text">₹38,20,000</td>
                            <td>
                                <span class="status-badge badge-pending">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="3"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
                                    Pending
                                </span>
                            </td>
                            <td class="date-text">Mar 11, 2024</td>
                            <td class="text-end">
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9e8e80" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                                <button class="action-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9534f" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
