@model IEnumerable<CarBazzar.Models.Entity.Car>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Listings Management";
}

<link rel="stylesheet" href="~/css/admin-listings.css" />

<section>
    <div class="mb-3 d-flex justify-content-end">
        <a asp-controller="Admin" asp-action="AddListing"
           class="btn d-inline-flex align-items-center gap-2 btn-add-listing">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Listing
        </a>
    </div>

    <div class="card section-card">
        <div class="card-body p-4">

            <!-- Filters -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="search-wrap">
                        <span class="search-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#b39b7c" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        </span>
                        <input class="form-control" placeholder="Search listings..." />
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Car</th>
                            <th>Seller ID</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Date Posted</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var car in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@Url.Action("GetImage", "Cars", new { id = car.Id })" class="car-thumbnail" onerror="this.src='/images/suv.jpg'" />
                                        <div>
                                            <div class="fw-semibold">@car.Title</div>
                                            <div class="text-muted car-description">@car.Year • @car.Transmission</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@(car.SellerId != null ? "User" : "Admin")</td>
                                <td class="price-text">₹@car.Price.ToString("N0")</td>
                                <td>
                                    @if(car.IsHidden) {
                                        <span class="status-badge bg-danger text-white border-0 px-2 py-1 rounded small">Hidden</span>
                                    } else {
                                        <span class="status-badge badge-approved"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#138a4a" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Approved</span>
                                    }
                                </td>
                                <td class="date-text">@car.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end d-flex justify-content-end gap-2">
                                    <a href="@Url.Action("Details", "Cars", new { id = car.Id })" class="action-btn text-primary" title="View">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </a>
                                    <form asp-action="HideListing" asp-route-id="@car.Id" method="post" style="display:inline;">
                                        <button type="submit" class="action-btn text-warning border-0 bg-transparent" title="@(car.IsHidden ? "Unhide" : "Hide")">
                                            @if (car.IsHidden) {
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                            } else {
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                            }
                                        </button>
                                    </form>
                                    <form asp-action="DeleteListing" asp-route-id="@car.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                        <button type="submit" class="action-btn text-danger border-0 bg-transparent" title="Delete">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center text-muted mt-4">
                    <p>No listings found.</p>
                </div>
            }
        </div>
    </div>
</section>
