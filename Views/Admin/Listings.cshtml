@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Listings Management";
}

<section>
    <div class="mb-3 d-flex justify-content-end">
        <a asp-controller="Admin" asp-action="AddListing"
           class="btn"
           style="background:#f97316;color:#fff;font-weight:600;border-radius:999px;padding:8px 18px;border:none;">+ Add Listing</a>
    </div>

    <div class="card border-0" style="border-radius:18px;box-shadow:0 10px 34px rgba(0,0,0,.06);">
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <input class="form-control" placeholder="Search listings..." style="border-radius:999px;border-color:#e5ded3;font-size:13px;padding:9px 14px;" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" style="border-radius:999px;border-color:#e5ded3;font-size:13px;padding:9px 14px;">
                        <option>All Status</option>
                        <option>Approved</option>
                        <option>Pending</option>
                        <option>Rejected</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" style="border-radius:999px;border-color:#e5ded3;font-size:13px;padding:9px 14px;">
                        <option>All Brands</option>
                        <option>Toyota</option>
                        <option>Honda</option>
                        <option>BMW</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr style="font-size:12px;color:#a29a8d;text-transform:uppercase;letter-spacing:.12em;">
                            <th scope="col">Car</th>
                            <th scope="col">Seller</th>
                            <th scope="col">Price</th>
                            <th scope="col">Status</th>
                            <th scope="col">Date Posted</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody style="font-size:13px;color:#40352c;">
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/2721-inset12-2024-maserati-mc20.png" style="width:46px;height:34px;border-radius:8px;object-fit:cover;" />
                                    <div>
                                        <div class="fw-semibold">Toyota Camry</div>
                                        <div class="text-muted" style="font-size:12px;">2022 • Sedan</div>
                                    </div>
                                </div>
                            </td>
                            <td>Ajay shah</td>
                            <td style="color:#e65100;font-weight:700;">₹28,50,000</td>
                            <td><span class="badge rounded-pill" style="background:#e6f7ef;color:#138a4a;font-size:11px;">Approved</span></td>
                            <td>Mar 15, 2024</td>
                            <td class="text-end text-muted">
                                <span style="cursor:pointer;margin-right:8px;">👁️</span>
                                <span style="cursor:pointer;margin-right:8px;">✏️</span>
                                <span style="cursor:pointer;">🗑️</span>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" style="width:46px;height:34px;border-radius:8px;object-fit:cover;" />
                                    <div>
                                        <div class="fw-semibold">Honda Civic</div>
                                        <div class="text-muted" style="font-size:12px;">2023 • Hatchback</div>
                                    </div>
                                </div>
                            </td>
                            <td>Mansi</td>
                            <td style="color:#e65100;font-weight:700;">₹22,24,900</td>
                            <td><span class="badge rounded-pill" style="background:#fff5eb;color:#f97316;font-size:11px;">Pending</span></td>
                            <td>Mar 14, 2024</td>
                            <td class="text-end text-muted">
                                <span style="cursor:pointer;margin-right:8px;">👁️</span>
                                <span style="cursor:pointer;margin-right:8px;">✏️</span>
                                <span style="cursor:pointer;">🗑️</span>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" style="width:46px;height:34px;border-radius:8px;object-fit:cover;" />
                                    <div>
                                        <div class="fw-semibold">BMW X5</div>
                                        <div class="text-muted" style="font-size:12px;">2021 • SUV</div>
                                    </div>
                                </div>
                            </td>
                            <td>Vikram</td>
                            <td style="color:#e65100;font-weight:700;">₹52,00,000</td>
                            <td><span class="badge rounded-pill" style="background:#fdeae9;color:#d9534f;font-size:11px;">Rejected</span></td>
                            <td>Mar 13, 2024</td>
                            <td class="text-end text-muted">
                                <span style="cursor:pointer;margin-right:8px;">👁️</span>
                                <span style="cursor:pointer;margin-right:8px;">✏️</span>
                                <span style="cursor:pointer;">🗑️</span>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" style="width:46px;height:34px;border-radius:8px;object-fit:cover;" />
                                    <div>
                                        <div class="fw-semibold">Mercedes C-Class</div>
                                        <div class="text-muted" style="font-size:12px;">2022 • Sedan</div>
                                    </div>
                                </div>
                            </td>
                            <td>Arjun singh</td>
                            <td style="color:#e65100;font-weight:700;">₹45,80,000</td>
                            <td><span class="badge rounded-pill" style="background:#e6f7ef;color:#138a4a;font-size:11px;">Approved</span></td>
                            <td>Mar 12, 2024</td>
                            <td class="text-end text-muted">
                                <span style="cursor:pointer;margin-right:8px;">👁️</span>
                                <span style="cursor:pointer;margin-right:8px;">✏️</span>
                                <span style="cursor:pointer;">🗑️</span>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/Car Hero.png" style="width:46px;height:34px;border-radius:8px;object-fit:cover;" />
                                    <div>
                                        <div class="fw-semibold">Audi A4</div>
                                        <div class="text-muted" style="font-size:12px;">2023 • Sedan</div>
                                    </div>
                                </div>
                            </td>
                            <td>Rajesh kumar</td>
                            <td style="color:#e65100;font-weight:700;">₹38,20,000</td>
                            <td><span class="badge rounded-pill" style="background:#fff5eb;color:#f97316;font-size:11px;">Pending</span></td>
                            <td>Mar 11, 2024</td>
                            <td class="text-end text-muted">
                                <span style="cursor:pointer;margin-right:8px;">👁️</span>
                                <span style="cursor:pointer;margin-right:8px;">✏️</span>
                                <span style="cursor:pointer;">🗑️</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

