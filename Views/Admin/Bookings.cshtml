@model IEnumerable<CarBazzar.Models.Booking>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Platform Bookings";
}
<link href="~/css/admin-listings.css" rel="stylesheet" />
<section>
    <div class="card section-card">
        <div class="card-body p-4">
            <h5 class="mb-4 fw-bold" style="color:#1a1008;">All Bookings</h5>

            <div class="table-responsive">
                <table class="table mb-0" style="border-collapse: separate; border-spacing: 0;">
                    <thead>
                        <tr>
                            <th style="font-size: 11px; color: #a29a8d; text-transform: uppercase; font-weight: 600; padding-bottom: 12px; border-bottom: 1px solid #f0ece7;">CAR DETAILS</th>
                            <th style="font-size: 11px; color: #a29a8d; text-transform: uppercase; font-weight: 600; padding-bottom: 12px; border-bottom: 1px solid #f0ece7;">BOOKED BY</th>
                            <th style="font-size: 11px; color: #a29a8d; text-transform: uppercase; font-weight: 600; padding-bottom: 12px; border-bottom: 1px solid #f0ece7;">PHONE</th>
                            <th style="font-size: 11px; color: #a29a8d; text-transform: uppercase; font-weight: 600; padding-bottom: 12px; border-bottom: 1px solid #f0ece7;">APPOINTMENT DATE</th>
                            <th style="font-size: 11px; color: #a29a8d; text-transform: uppercase; font-weight: 600; padding-bottom: 12px; border-bottom: 1px solid #f0ece7;">STATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(!Model.Any()) {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">No bookings found on the platform yet.</td>
                            </tr>
                        }
                        @foreach(var booking in Model)
                        {
                            <tr style="border-bottom: 1px solid #f7f4f1;">
                                <td style="padding: 16px 8px;">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width: 52px; height: 38px; border-radius: 8px; background: #e5ded3; overflow: hidden;">
                                            @if (booking.Car != null) {
                                                <img src="@Url.Action("GetImage", "Cars", new { id = booking.CarId })" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='/images/suv.jpg'"/>
                                            } else {
                                                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;"><svg width="20" height="20" stroke="#a29a8d" fill="none" stroke-width="2"><path d="M3 13h18"/><path d="M16 8l-2-4H10L8 8H4v9h16V8h-4z"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="16.5" cy="17.5" r="2.5"/></svg></div>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-bold" style="color: #1a1008; font-size: 13px;">@(booking.Car?.Title ?? "Deleted Car")</div>
                                            <div style="color: #a29a8d; font-size: 13px;">₹@(booking.Car?.Price.ToString("N0") ?? "0")</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 16px 8px; color: #1a1008; font-size: 13px; font-weight: 500;">
                                    @(booking.User?.FirstName ?? "Unknown")
                                </td>
                                <td style="padding: 16px 8px; color: #f97316; font-size: 13px; font-weight: 700;">
                                    @(booking.MobileNumber ?? "N/A")
                                </td>
                                <td style="padding: 16px 8px; color: #6b5f54; font-size: 13px;">
                                    @booking.BookingDate.ToString("M/d/yyyy, h:mm:ss tt")
                                </td>
                                <td style="padding: 16px 8px; color: #1a1008; font-size: 13px; font-weight: 700;">
                                    confirmed
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
