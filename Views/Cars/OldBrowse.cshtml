@model IReadOnlyList<CarBazzar.Models.Cars.CarCard>
@{
    ViewData["Title"] = "Buy Old Car";
}

<section class="py-5" style="background: #fffaf5; min-height: 100vh;">
    <div class="container">

        <div class="mb-5">
            <h1 class="fw-bold mb-1" style="color: #1a202c; font-size: 36px;">Buy Old Car</h1>
            <p class="text-muted fs-5">Explore quality pre-owned vehicles at great prices</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-3">
                <div class="filter-sidebar">

                    <div class="filter-group mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="filter-title mb-0">Brands</h6>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a0aec0" stroke-width="2.5"><path d="M18 15l-6-6-6 6"/></svg>
                        </div>
                        <div class="filter-options">
                            <label class="filter-check"><input type="checkbox" checked> <span class="check-label">All Brands</span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Mercedes-Benz <span class="cnt">14</span></span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">BMW <span class="cnt">23</span></span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Audi <span class="cnt">8</span></span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Tesla <span class="cnt">11</span></span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Porsche <span class="cnt">5</span></span></label>
                        </div>
                    </div>

                    <hr class="filter-divider" />

                    <div class="filter-group mb-4">
                        <h6 class="filter-title">Price Range</h6>
                        <div class="range-wrap mb-3">
                            <input type="range" class="price-range" id="priceRange" min="5000" max="150000" value="80000" step="1000">
                        </div>
                        <div class="d-flex gap-2">
                            <div class="price-box"><span class="cur">₹</span><input type="text" id="minPrice" value="10,000" class="price-inp" readonly></div>
                            <div class="price-box"><span class="cur">₹</span><input type="text" id="maxPrice" value="80,000" class="price-inp" readonly></div>
                        </div>
                    </div>

                    <hr class="filter-divider" />

                    <div class="filter-group">
                        <h6 class="filter-title">Fuel Type</h6>
                        <div class="filter-options">
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Petrol</span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Diesel</span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Electric</span></label>
                            <label class="filter-check"><input type="checkbox"> <span class="check-label">Hybrid</span></label>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-lg-9">
                <div class="mb-4">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-8">
                            <div class="search-wrap">
                                <svg class="s-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                                </svg>
                                <input type="text" class="form-control" placeholder="Search cars by name, brand or model...">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center justify-content-md-end gap-2">
                                <span class="text-muted small text-nowrap">Sort by:</span>
                                <select class="form-select sort-sel">
                                    <option>Newest First</option>
                                    <option>Price: Low to High</option>
                                    <option>Price: High to Low</option>
                                    <option>Mileage: Low to High</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    @foreach (var car in Model)
                    {
                        <div class="col-md-4">
                            <div class="old-card">
                                <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@car.Id" class="wish-form">
                                    <button type="submit" class="wish-btn @(CarBazzar.Models.WishlistStore.IsSaved(car.Id) ? "active" : "")">
                                        <svg width="15" height="15" viewBox="0 0 24 24"
                                             fill="@(CarBazzar.Models.WishlistStore.IsSaved(car.Id) ? "#f07500" : "none")"
                                             stroke="currentColor" stroke-width="2">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                        </svg>
                                    </button>
                                </form>
                                <a asp-controller="Cars" asp-action="OldDetails" asp-route-id="@car.Id" class="text-decoration-none">
                                    <div class="card-img-wrap">
                                        <img src="@car.ImageUrl" alt="@car.Title" class="old-img" />
                                    </div>
                                    <div class="old-body">
                                        <h5 class="old-title">@car.Title</h5>
                                        <p class="old-sub">@car.Specs</p>
                                        <div class="old-price">@car.Price</div>
                                        <div class="old-meta">
                                            <span class="meta-pill">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                                @car.Year
                                            </span>
                                            <span class="meta-pill">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 22V8l9-6 9 6v14H3z"/></svg>
                                                @car.FuelType
                                            </span>
                                            <span class="meta-pill">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                                                @car.Mileage
                                            </span>
                                        </div>
                                        <div class="view-details-btn">View Details</div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .filter-sidebar {
        background: #fff; border-radius: 20px; padding: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05); position: sticky; top: 20px;
    }
    .filter-title { font-weight: 700; color: #1a202c; font-size: 15px; margin-bottom: 14px; }
    .filter-options { display: flex; flex-direction: column; gap: 10px; }
    .filter-divider { border-color: #f0ebe3; margin: 4px 0 16px; }
    .filter-check { display: flex; align-items: center; gap: 10px; cursor: pointer; font-size: 14px; color: #4a5568; }
    .filter-check input[type="checkbox"] { width: 16px; height: 16px; accent-color: #f07500; }
    .check-label { display: flex; align-items: center; gap: 6px; }
    .cnt { font-size: 12px; color: #a0aec0; }

    .price-range {
        -webkit-appearance: none; width: 100%; height: 4px;
        border-radius: 2px; outline: none;
        background: linear-gradient(to right, #f07500 53%, #e2e8f0 53%);
    }
    .price-range::-webkit-slider-thumb {
        -webkit-appearance: none; width: 18px; height: 18px;
        border-radius: 50%; background: #f07500; cursor: pointer;
        box-shadow: 0 2px 6px rgba(240,117,0,0.35);
    }
    .price-box { position: relative; flex: 1; }
    .cur { position: absolute; left: 9px; top: 50%; transform: translateY(-50%); color: #718096; font-size: 13px; }
    .price-inp { width: 100%; padding: 8px 8px 8px 20px; border: 1px solid #e2e8f0; border-radius: 10px; font-size: 13px; color: #2d3748; background: #fafafa; }

    .search-wrap { position: relative; }
    .s-icon { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #a0aec0; }
    .search-wrap .form-control { height: 48px; border-radius: 999px; border: 1px solid #e2e8f0; font-size: 14px; padding-left: 46px; }
    .search-wrap .form-control:focus { border-color: #f07500; box-shadow: 0 0 0 3px rgba(240,117,0,0.1); outline: none; }
    .sort-sel { height: 44px; border-radius: 10px; border: 1px solid #e2e8f0; font-size: 14px; min-width: 150px; }
    .sort-sel:focus { border-color: #f07500; box-shadow: none; }

    .old-card {
        background: #fff; border-radius: 18px; overflow: hidden;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06); position: relative;
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .old-card:hover { transform: translateY(-6px); box-shadow: 0 14px 30px rgba(0,0,0,0.1); }
    .card-img-wrap { overflow: hidden; }
    .old-img { width: 100%; height: 200px; object-fit: cover; display: block; transition: transform 0.4s; }
    .old-card:hover .old-img { transform: scale(1.04); }

    .wish-form { position: absolute; top: 12px; right: 12px; z-index: 2; }
    .wish-btn {
        width: 34px; height: 34px; border-radius: 50%;
        background: #fff; border: none;
        display: flex; align-items: center; justify-content: center;
        color: #718096; box-shadow: 0 2px 8px rgba(0,0,0,0.12); cursor: pointer; transition: all 0.2s;
    }
    .wish-btn:hover, .wish-btn.active { color: #f07500; transform: scale(1.1); }

    .old-body { padding: 16px 18px 18px; }
    .old-title { font-size: 16px; font-weight: 700; color: #1a202c; margin-bottom: 2px; }
    .old-sub { font-size: 13px; color: #a0aec0; margin-bottom: 8px; }
    .old-price { font-size: 20px; font-weight: 800; color: #f07500; margin-bottom: 10px; }
    .old-meta { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
    .meta-pill {
        display: flex; align-items: center; gap: 4px;
        background: #f7f7f7; border-radius: 6px; padding: 4px 8px;
        font-size: 12px; color: #718096; font-weight: 500;
    }
    .view-details-btn {
        background: #fff5eb; color: #8a5e3b; font-weight: 700;
        border-radius: 10px; padding: 10px; text-align: center; font-size: 14px;
        transition: background 0.2s, color 0.2s;
    }
    .old-card:hover .view-details-btn { background: #f07500; color: #fff; }
</style>