@model IReadOnlyList<CarBazzar.Models.Cars.CarCard>
@{
    ViewData["Title"] = "Used Cars Marketplace";
}

<section class="py-5" style="background: #f8fafc; min-height: 100vh;">
    <div class="container">
        
        <!-- Header -->
        <div class="mb-5">
            <h1 class="fw-bold mb-1" style="color: #0f172a; font-size: 36px;">Used Cars Marketplace</h1>
            <p class="text-muted fs-5">Buy directly from trusted sellers at best prices</p>
        </div>

        <div class="row g-4">
            <!-- Sidebar Filters -->
            <div class="col-lg-3">
                <div class="marketplace-sidebar">
                    
                    <div class="filter-group mb-4">
                        <h6 class="market-filter-title">Quick Filters</h6>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <span class="badge rounded-pill px-3 py-2" style="background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; cursor: pointer;">Verified Seller</span>
                            <span class="badge rounded-pill px-3 py-2" style="background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; cursor: pointer;">Low Mileage</span>
                            <span class="badge rounded-pill px-3 py-2" style="background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; cursor: pointer;">First Owner</span>
                        </div>
                    </div>

                    <div class="filter-group mb-4">
                        <h6 class="market-filter-title">Budget Range</h6>
                        <div class="mt-3">
                            <input type="range" class="form-range custom-range" min="1000" max="50000" step="1000">
                            <div class="d-flex justify-content-between mt-2">
                                <span class="fw-bold text-dark">$1,000</span>
                                <span class="fw-bold text-dark">$50,000+</span>
                            </div>
                        </div>
                    </div>

                    <div class="filter-group mb-4">
                        <h6 class="market-filter-title">Body Type</h6>
                        <div class="market-options mt-3">
                            <label class="market-check">
                                <input type="checkbox" checked>
                                <span>Sedan</span>
                            </label>
                            <label class="market-check">
                                <input type="checkbox">
                                <span>SUV</span>
                            </label>
                            <label class="market-check">
                                <input type="checkbox">
                                <span>Hatchback</span>
                            </label>
                            <label class="market-check">
                                <input type="checkbox">
                                <span>Coupe</span>
                            </label>
                        </div>
                    </div>

                    <div class="filter-group">
                        <h6 class="market-filter-title">Location</h6>
                        <select class="form-select mt-3" style="border-radius: 10px;">
                            <option>All Cities</option>
                            <option>Rajkot</option>
                            <option>Ahmedabad</option>
                            <option>Surat</option>
                        </select>
                    </div>

                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                
                <!-- Search Bar -->
                <div class="market-search mb-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px; padding-left: 20px;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control border-start-0 py-3" placeholder="Search used cars, sellers or locations..." style="border-radius: 0 12px 12px 0; font-size: 16px;">
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="results-info">
                        <span class="fw-bold text-dark">@Model.Count</span> used cars available
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small">Sort by:</span>
                        <select class="form-select w-auto border-0 bg-transparent fw-bold" style="cursor: pointer;">
                            <option>Most Recent</option>
                            <option>Lowest Price</option>
                            <option>Highest Price</option>
                        </select>
                    </div>
                </div>

                <!-- Marketplace Grid -->
                <div class="row g-4">
                    @foreach (var car in Model)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="market-card">
                                <div class="market-card-img-wrapper">
                                    <img src="@car.ImageUrl" alt="@car.Title" class="market-card-img">
                                    <div class="market-seller-badge">
                                        <div class="seller-avatar">@car.Title[0]</div>
                                        <span>Verified Seller</span>
                                    </div>
                                    <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@car.Id" class="market-wishlist-pos">
                                        <button type="submit" class="market-wish-btn @(CarBazzar.Models.WishlistStore.IsSaved(car.Id) ? "active" : "")">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="@(CarBazzar.Models.WishlistStore.IsSaved(car.Id) ? "#ef4444" : "none")" stroke="currentColor" stroke-width="2">
                                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                                <div class="market-card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="market-card-title m-0">@car.Title</h6>
                                        <div class="market-card-price">@car.Price</div>
                                    </div>
                                    <div class="market-card-meta mb-3">
                                        <div class="meta-item">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                                            @car.Specs.Split('•')[0]
                                        </div>
                                        <div class="meta-item">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                            12k km
                                        </div>
                                    </div>
                                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="market-card-btn">Contact Seller</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>

    </div>
</section>

<style>
    .marketplace-sidebar {
        background: #fff;
        border-radius: 24px;
        padding: 28px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.03);
    }

    .market-filter-title {
        font-weight: 800;
        color: #0f172a;
        font-size: 15px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .market-check {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 8px 0;
        font-size: 14px;
        color: #475569;
        font-weight: 500;
    }

    .market-check input {
        width: 18px;
        height: 18px;
        accent-color: #0f172a;
    }

    .custom-range::-webkit-slider-thumb {
        background: #0f172a;
    }

    .market-card {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid #f1f5f9;
        transition: all 0.3s ease;
    }

    .market-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
    }

    .market-card-img-wrapper {
        position: relative;
        height: 200px;
    }

    .market-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .market-seller-badge {
        position: absolute;
        bottom: 12px;
        left: 12px;
        background: rgba(15, 23, 42, 0.85);
        backdrop-filter: blur(4px);
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 600;
    }

    .seller-avatar {
        width: 18px;
        height: 18px;
        background: #3b82f6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
    }

    .market-wishlist-pos {
        position: absolute;
        top: 12px;
        right: 12px;
    }

    .market-wish-btn {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        transition: all 0.2s;
    }

    .market-wish-btn.active {
        color: #ef4444;
    }

    .market-card-body {
        padding: 20px;
    }

    .market-card-title {
        font-size: 17px;
        font-weight: 700;
        color: #0f172a;
    }

    .market-card-price {
        font-size: 18px;
        font-weight: 800;
        color: #0f172a;
    }

    .market-card-meta {
        display: flex;
        gap: 16px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #64748b;
        font-weight: 500;
    }

    .market-card-btn {
        display: block;
        width: 100%;
        padding: 12px;
        background: #f1f5f9;
        color: #0f172a;
        text-align: center;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        border-radius: 14px;
        transition: all 0.2s;
    }

    .market-card-btn:hover {
        background: #0f172a;
        color: #fff;
    }
</style>

