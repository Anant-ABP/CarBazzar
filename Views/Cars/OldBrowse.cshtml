@model IReadOnlyList<CarBazzar.Models.Cars.CarCard>
@{
    ViewData["Title"] = "Buy Old Car";
    var wishlistIds = ViewBag.WishlistCarIds as List<int> ?? new List<int>();
}
<link rel="stylesheet" href="~/css/cars-oldbrowse.css" />

<section class="py-5 oldbrowse-section">
    <div class="container">

        <div class="mb-5">
            <h1 class="fw-bold mb-1 oldbrowse-title">Buy Old Car</h1>
            <p class="text-muted fs-5">Explore quality pre-owned vehicles at great prices</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-3">
                <form id="filterForm" method="get" asp-action="OldBrowse" class="filter-sidebar">

                    <div class="filter-group mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="filter-title mb-0">Brands</h6>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a0aec0" stroke-width="2.5"><path d="M18 15l-6-6-6 6"/></svg>
                        </div>
                        <div class="filter-options">
                            <label class="filter-radio"><input type="radio" name="brand" value="" checked> <span class="check-label">All Brands</span></label>
                            <label class="filter-radio"><input type="radio" name="brand" value="Mercedes-Benz"> <span class="check-label">Mercedes-Benz</span></label>
                            <label class="filter-radio"><input type="radio" name="brand" value="BMW"> <span class="check-label">BMW</span></label>
                            <label class="filter-radio"><input type="radio" name="brand" value="Audi"> <span class="check-label">Audi</span></label>
                            <label class="filter-radio"><input type="radio" name="brand" value="Tesla"> <span class="check-label">Tesla</span></label>
                            <label class="filter-radio"><input type="radio" name="brand" value="Porsche"> <span class="check-label">Porsche</span></label>
                        </div>
                    </div>

                    <hr class="filter-divider" />

                    <div class="filter-group mb-4">
                        <h6 class="filter-title">Price Range</h6>
                        <div class="d-flex gap-2 mt-3">
                            <div class="price-box"><span class="cur">₹</span><input type="number" name="minPrice" placeholder="Min" class="price-inp"></div>
                            <div class="price-box"><span class="cur">₹</span><input type="number" name="maxPrice" placeholder="Max" class="price-inp"></div>
                        </div>
                    </div>

                    <hr class="filter-divider" />

                    <div class="filter-group mb-4">
                        <h6 class="filter-title">Fuel Type</h6>
                        <div class="filter-options">
                            <label class="filter-radio"><input type="radio" name="fuel" value="" checked> <span class="check-label">All</span></label>
                            <label class="filter-radio"><input type="radio" name="fuel" value="Petrol"> <span class="check-label">Petrol</span></label>
                            <label class="filter-radio"><input type="radio" name="fuel" value="Diesel"> <span class="check-label">Diesel</span></label>
                            <label class="filter-radio"><input type="radio" name="fuel" value="Electric"> <span class="check-label">Electric</span></label>
                            <label class="filter-radio"><input type="radio" name="fuel" value="Hybrid"> <span class="check-label">Hybrid</span></label>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-warning w-100 fw-bold text-white" style="background:#f07500; border-color:#f07500;">Apply Filter</button>

                </form>
            </div>

            <div class="col-lg-9">
                <div class="mb-4">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-8">
                            <div class="search-wrap">
                                <svg class="s-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                                </svg>
                                <input type="text" name="search" form="filterForm" value="@ViewBag.Search" class="form-control" placeholder="Search cars by name, brand or model..." onkeypress="if(event.key === 'Enter'){ document.getElementById('filterForm').submit(); return false; }">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center justify-content-md-end gap-2">
                                <span class="text-muted small text-nowrap">Sort by:</span>
                                <select class="form-select sort-sel">
                                    <option>Newest First</option>
                                    <option>Price: Low to High</option>
                                    <option>Price: High to Low</option>
                                    <option>Mileage: Low to High</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    @foreach (var car in Model)
                    {
                        bool isSaved = wishlistIds.Contains(car.Id);
                        <div class="col-md-4">
                            <div class="old-card">
                                <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@car.Id" class="wish-form">
                                    <button type="submit" class="wish-btn @(isSaved ? "active" : "")">
                                        @if (isSaved)
                                        {
                                            <svg width="15" height="15" viewBox="0 0 24 24" fill="#f07500" stroke="#f07500" stroke-width="2">
                                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                            </svg>
                                        }
                                    </button>
                                </form>
                                <a asp-controller="Cars" asp-action="OldDetails" asp-route-id="@car.Id" class="text-decoration-none">
                                    <div class="card-img-wrap">
                                        <img src="@car.ImageUrl" alt="@car.Title" class="old-img" />
                                    </div>
                                    <div class="old-body">
                                        <h5 class="old-title">@car.Title</h5>
                                        <p class="old-sub">@car.Specs</p>
                                        <div class="old-price">@car.Price</div>
                                        <div class="old-meta">
                                            <span class="meta-pill">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                                @car.Year
                                            </span>
                                            <span class="meta-pill">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 22V8l9-6 9 6v14H3z"/></svg>
                                                @car.FuelType
                                            </span>
                                            <span class="meta-pill">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                                                @car.Mileage
                                            </span>
                                        </div>
                                        <div class="view-details-btn">View Details</div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

