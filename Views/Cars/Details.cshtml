@model CarBazzar.Models.Cars.CarCard
@{
    ViewData["Title"] = "Car Details - " + Model.Title;
}
<link rel="stylesheet" href="~/css/cars-details.css" />

<section class="py-5 details-section">
    <div class="container">

        <div class="mb-4">
            <a href="javascript:history.back()" class="back-link">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                Back to Listing
            </a>
        </div>

        <div class="row g-4">

            <!-- Left: Image + Description + Features -->
            <div class="col-lg-7">

                <div class="gallery-box">
                    <div id="carGallery" class="carousel slide">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="@Model.ImageUrl" alt="@Model.Title" class="gallery-img" />
                            </div>
                        </div>
                        <button class="gal-arrow gal-prev" type="button" data-bs-target="#carGallery" data-bs-slide="prev">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
                        </button>
                        <button class="gal-arrow gal-next" type="button" data-bs-target="#carGallery" data-bs-slide="next">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
                        </button>
                        <div class="gal-dots">
                            <span class="gdot active"></span>
                            <span class="gdot"></span>
                            <span class="gdot"></span>
                            <span class="gdot"></span>
                            <span class="gdot"></span>
                        </div>
                    </div>
                </div>

                <div class="detail-box mt-4">
                    <h5 class="box-heading">Description</h5>
                    <p class="details-description">
                        @(string.IsNullOrEmpty(Model.Description)
                            ? "Stunning vehicle in excellent condition with full service history. Factory warranty remaining. Ready for immediate delivery."
                            : Model.Description)
                    </p>
                </div>

                <div class="detail-box mt-4">
                    <h5 class="box-heading">Features</h5>
                    <div class="row g-1">
                        @{
                            var feats = (Model.Features != null && Model.Features.Count > 0)
                                ? Model.Features
                                : new List<string> { "Carbon Fiber Roof", "Head-Up Display", "Adaptive M Suspension", "M Carbon Bucket Seats", "Harman Kardon Audio", "M Drive Professional" };
                        }
                        @foreach (var f in feats)
                        {
                            <div class="col-md-6">
                                <div class="feat-row">
                                    <div class="feat-dot"></div>
                                    <span>@f</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>

            <!-- Right: Info Panel -->
            <div class="col-lg-5">
                <div class="info-panel">

                    <div class="d-flex align-items-start justify-content-between mb-1">
                        <h3 class="info-title">@Model.Title</h3>
                        <button class="share-btn" title="Share">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                        </button>
                    </div>

                    <div class="info-price mb-3">@Model.Price</div>

                    <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@Model.Id" class="mb-4">
                        <button type="submit" class="wish-action-btn">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            Add to Wishlist
                        </button>
                    </form>

                    <!-- Specs -->
                    <div class="panel-section">
                        <h5 class="box-heading">Specifications</h5>
                        <div class="specs-grid">
                            <div class="spec-cell">
                                <div class="spec-icon-wrap"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
                                <div><div class="spec-lbl">Year</div><div class="spec-val">@(Model.Year > 0 ? Model.Year.ToString() : "2024")</div></div>
                            </div>
                            <div class="spec-cell">
                                <div class="spec-icon-wrap"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg></div>
                                <div><div class="spec-lbl">Mileage</div><div class="spec-val">@(string.IsNullOrEmpty(Model.Mileage) ? "3,200 mi" : Model.Mileage)</div></div>
                            </div>
                            <div class="spec-cell">
                                <div class="spec-icon-wrap"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><path d="M3 22V8l9-6 9 6v14H3z"/></svg></div>
                                <div><div class="spec-lbl">Fuel</div><div class="spec-val">@(string.IsNullOrEmpty(Model.FuelType) ? "Gasoline" : Model.FuelType)</div></div>
                            </div>
                            <div class="spec-cell">
                                <div class="spec-icon-wrap"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
                                <div><div class="spec-lbl">Transmission</div><div class="spec-val">@(string.IsNullOrEmpty(Model.Transmission) ? "Automatic" : Model.Transmission)</div></div>
                            </div>
                            <div class="spec-cell">
                                <div class="spec-icon-wrap"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></div>
                                <div><div class="spec-lbl">Body</div><div class="spec-val">@(string.IsNullOrEmpty(Model.BodyType) ? "Coupe" : Model.BodyType)</div></div>
                            </div>
                            <div class="spec-cell">
                                <div class="spec-icon-wrap"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg></div>
                                <div><div class="spec-lbl">Color</div><div class="spec-val">@(string.IsNullOrEmpty(Model.Color) ? "Alpine White" : Model.Color)</div></div>
                            </div>
                        </div>
                    </div>

                    <!-- Seller Info -->
                    <div class="panel-section">
                        <h5 class="box-heading">Seller Information</h5>
                        <div class="seller-card">
                            <div class="seller-row">
                                <div class="seller-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                                <span class="seller-txt">@(string.IsNullOrEmpty(Model.DealerName) ? "Premium Auto Gallery" : Model.DealerName)</span>
                            </div>
                            <div class="seller-row">
                                <div class="seller-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
                                <span class="seller-txt">@(string.IsNullOrEmpty(Model.DealerPhone) ? "(310) 555-0142" : Model.DealerPhone)</span>
                            </div>
                            <div class="seller-row">
                                <div class="seller-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
                                <span class="seller-txt">@(string.IsNullOrEmpty(Model.DealerLocation) ? "Los Angeles, CA" : Model.DealerLocation)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Button -->
                    <button asp-controller="Messages" asp-action="Index" asp-route-carId="@Model.Id" class="contact-btn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Contact Seller
                    </button>

                </div>
            </div>

        </div>
    </div>
</section>

