@model IReadOnlyList<CarBazzar.Models.Cars.CarCard>
@{
    ViewData["Title"] = "Browse Cars";
}
<link rel="stylesheet" href="~/css/cars-browse.css" />

<section class="py-5 browse-section">
    <div class="container">

        <div class="mb-5">
            <h1 class="fw-bold mb-1 browse-title">Browse Cars</h1>
            <p class="text-muted fs-5">Find your perfect vehicle from our collection</p>
        </div>

        <div class="row g-4">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="filter-sidebar">

                    <div class="filter-group mb-4">
                        <h6 class="filter-title">Brands</h6>
                        <div class="filter-options">
                            <label class="filter-radio"><input type="radio" name="brand" checked> <span class="radio-label">All Brands</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">Mercedes-Benz</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">BMW</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">Audi</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">Tesla</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">Porsche</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">Ford</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">Chevrolet</span></label>
                            <label class="filter-radio"><input type="radio" name="brand"> <span class="radio-label">Nissan</span></label>
                        </div>
                    </div>

                    <div class="filter-group mb-4">
                        <h6 class="filter-title">Price Range</h6>
                        <div class="price-input-wrapper">
                            <span class="currency">₹</span>
                            <input type="number" value="10000" class="form-control">
                        </div>
                        <div class="price-input-wrapper mt-2">
                            <span class="currency">₹</span>
                            <input type="number" value="120000" class="form-control">
                        </div>
                    </div>

                    <div class="filter-group">
                        <h6 class="filter-title">Fuel Type</h6>
                        <div class="filter-options">
                            <label class="filter-radio"><input type="radio" name="fuel" checked> <span class="radio-label">All</span></label>
                            <label class="filter-radio"><input type="radio" name="fuel"> <span class="radio-label">Gasoline</span></label>
                            <label class="filter-radio"><input type="radio" name="fuel"> <span class="radio-label">Hybrid</span></label>
                            <label class="filter-radio"><input type="radio" name="fuel"> <span class="radio-label">Electric</span></label>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Main -->
            <div class="col-lg-9">

                <div class="search-sort-bar mb-4">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-7">
                            <div class="search-wrapper">
                                <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                                </svg>
                                <input type="text" class="form-control ps-5" placeholder="Search cars by name, brand or model...">
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="d-flex align-items-center justify-content-md-end gap-3">
                                <span class="text-muted small text-nowrap">Sort by:</span>
                                <select class="form-select w-auto">
                                    <option>Newest First</option>
                                    <option>Price: Low to High</option>
                                    <option>Price: High to Low</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="fw-medium text-muted">@Model.Count cars found</div>
                    <button class="reset-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                        </svg>
                        Reset filters
                    </button>
                </div>

                <div class="row g-4">
                    @foreach (var car in Model)
                    {
                        <div class="col-md-4">
                            <div class="car-card">
                                <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@car.Id" class="wish-pos">
                                    <button type="submit" class="wish-btn @(CarBazzar.Models.WishlistStore.IsSaved(car.Id) ? "active" : "")">
                                        <svg width="17" height="17" viewBox="0 0 24 24"
                                             fill="@(CarBazzar.Models.WishlistStore.IsSaved(car.Id) ? "#f07500" : "none")"
                                             stroke="currentColor" stroke-width="2">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                        </svg>
                                    </button>
                                </form>
                                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="text-decoration-none">
                                    <div class="card-img-wrap">
                                        <img src="@car.ImageUrl" alt="@car.Title" class="card-car-img" />
                                    </div>
                                    <div class="card-body-inner">
                                        <h5 class="card-car-title">@car.Title</h5>
                                        <p class="card-car-sub">@car.Specs</p>
                                        <div class="card-car-price">@car.Price</div>
                                        <div class="card-car-specs">
                                            <span>@car.Year</span>
                                            <span>@car.FuelType</span>
                                            <span>@car.Mileage</span>
                                        </div>
                                        <div class="card-view-btn">View Details</div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</section>

