@model CarBazzar.Models.Profile.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}
<link rel="stylesheet" href="~/css/profile-index.css" />

<section class="py-5 profile-section">
    <div class="container">
        
        <h1 class="fw-bold mb-4 profile-title">My Profile</h1>

        <!-- Stats Card -->
        <div class="profile-stats-card mb-5">
            <div class="row align-items-center">
                <div class="col-auto">
                    <div class="profile-avatar-large">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </div>
                </div>
                <div class="col">
                    <div class="row g-4">
                        <div class="col-auto border-end pe-4">
                            <div class="stat-value">Total Listings: @Model.TotalListings</div>
                            <div class="stat-label">Monthly active listings</div>
                        </div>
                        <div class="col-auto ps-4">
                            <div class="stat-value">Cars Wishlisted: @Model.WishlistCount</div>
                            <div class="stat-label">Verified sales records</div>
                        </div>
                    </div>
                </div>
                <div class="col-auto">
                    <a asp-controller="Cars" asp-action="Sell" class="btn btn-outline-warning px-4 py-2 fw-bold profile-btn-sell">
                        + List a New car
                    </a>
                </div>
            </div>
        </div>

        <!-- Personal Information Section -->
        <div class="section-container mb-5">
            <h4 class="fw-bold mb-4 profile-title">Personal Information</h4>
            <div class="info-card">
                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Full Name</label>
                        <input type="text" class="form-control info-input" value="@Model.FullName" readonly>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Email</label>
                        <input type="text" class="form-control info-input" value="@Model.Email" readonly>
                    </div><br/>
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Phone</label>
                        <input type="text" class="form-control info-input" value="@Model.Phone" readonly>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-muted small fw-bold">Location</label>
                        <div class="position-relative">
                            <input type="text" class="form-control info-input" value="@Model.Location" readonly>
                        </div>
                    </div>
                    <div class="col-md-4 d-flex align-items-end justify-content-end">
                        <a asp-controller="Profile" asp-action="Edit" class="btn btn-outline-success px-5 py-2 fw-bold profile-btn-edit">
                            Edit Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recently Viewed Section -->
        <div class="section-container">
            <h4 class="fw-bold mb-4 profile-title">Recently Viewed Cars</h4>
            <div class="row g-4">
                @if (Model.RecentlyViewedCars != null && Model.RecentlyViewedCars.Any())
                {
                    foreach (var car in Model.RecentlyViewedCars)
                    {
                        <div class="col-md-3">
                            <a href="@Url.Action("Details", "Cars", new { id = car.Id })">
                                <div class="recent-car-card">
                                    <div class="recent-car-img-wrapper" style="height: 160px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                                        <img src="@car.ImageUrl" alt="@car.Title" class="recent-car-img" style="width: 100%; height: 100%; object-fit: cover;">
                                    </div>
                                    <div class="p-2">
                                        <h6 class="text-dark fw-bold mb-1">@car.Title</h6>
                                        <span class="text-muted small">@car.Price</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-muted">You haven't viewed any cars recently.</div>
                }
            </div>
        </div>

    </div>
</section>



