@model CarBazzar.Models.Cars.CarCard
@{
    ViewData["Title"] = "Messages";
}

<link rel="stylesheet" href="~/css/messages-index.css" />



<section class="py-4">
    <div class="container">
        <div class="chat-shell">

            <!-- LEFT SIDEBAR -->
            <aside class="chat-aside">
                <div class="chat-aside-head">
                    <div class="fw-semibold">Messages</div>
                </div>

                <div class="chat-list">

                    <button class="chat-item is-active" type="button" onclick="switchChat(this,'Arjun','A','')">
                        <div class="avatar">A</div>
                        <div class="meta">
                            <div class="top">
                                <div class="name">Arjun</div>
                                <div class="time">2m</div>
                            </div>
                            <div class="sub">Available for a test drive!</div>
                        </div>
                    </button>

                    <button class="chat-item" type="button" onclick="switchChat(this,'Sneha','S','av-g')">
                        <div class="avatar av-g">S</div>
                        <div class="meta">
                            <div class="top">
                                <div class="name">Sneha</div>
                                <div class="time">2h</div>
                            </div>
                            <div class="sub">Thanks for the info!</div>
                        </div>
                    </button>

                    <button class="chat-item" type="button" onclick="switchChat(this,'Rahul','R','av-b')">
                        <div class="avatar av-b">R</div>
                        <div class="meta">
                            <div class="top">
                                <div class="name">Rahul</div>
                                <div class="time">1d</div>
                            </div>
                            <div class="sub">Is the price negotiable?</div>
                        </div>
                    </button>

                    <button class="chat-item" type="button" onclick="switchChat(this,'Priya','P','av-p')">
                        <div class="avatar av-p">P</div>
                        <div class="meta">
                            <div class="top">
                                <div class="name">Priya</div>
                                <div class="time">2d</div>
                            </div>
                            <div class="sub">Can we schedule a viewing?</div>
                        </div>
                    </button>

                    <button class="chat-item" type="button" onclick="switchChat(this,'Vikram','V','av-t')">
                        <div class="avatar av-t">V</div>
                        <div class="meta">
                            <div class="top">
                                <div class="name">Vikram</div>
                                <div class="time">3d</div>
                            </div>
                            <div class="sub">What is the last price?</div>
                        </div>
                    </button>

                </div>
            </aside>

            <!-- MAIN CHAT -->
            <main class="chat-main">
                <div class="chat-main-head">
                    <div class="d-flex align-items-center gap-2">
                        <div class="avatar" id="hdrAvatar">A</div>
                        <div class="fw-semibold" id="hdrName">Arjun</div>
                    </div>
                </div>

                <div class="chat-thread" id="chatThread">
                    <div class="chat-date">Today, 10:23 AM</div>

                    <div class="bubble left">
                        Hi there! I saw your listing for the Maruti Swift. Do you have any questions?
                        <div class="t">10:23 AM</div>
                    </div>

                    <div class="bubble right">
                        Hey Arjun, yes! Is the car still available? I'm located in Mumbai as well.
                        <div class="t">10:24 AM</div>
                    </div>

                    <div class="bubble left">
                        Yes, it's still available. I'm free this weekend if you want to take a look.
                        <div class="t">10:26 AM</div>
                    </div>

                    <div class="bubble right">
                        That sounds great. Would Saturday morning work for you? Say around 10 AM?
                        <div class="t">10:30 AM</div>
                    </div>

                    <div class="bubble left">
                        Saturday 10 AM works perfectly. We can meet at Andheri Metro Station.
                        <div class="t">10:32 AM</div>
                    </div>
                </div>

                <div class="chat-compose">
                    <input id="chatInput" placeholder="Type a message..." />
                    <button class="send" type="button" aria-label="Send" id="chatSend">➤</button>
                </div>
            </main>

            <!-- RIGHT DETAIL -->
            <aside class="chat-detail">
                <div class="fw-semibold mb-2">Listing Details</div>
                <div class="detail-card">
                    <img src="@Model.ImageUrl" alt="@Model.Title" />
                    <div class="p-3">
                        <div class="detail-price">@Model.Price</div>
                        <div class="fw-semibold">@Model.Title</div>
                        <div class="small text-muted mb-3">Premium</div>

                        <div class="spec">
                            <div class="k">Mileage</div>
                            <div class="v">28,000 km</div>
                        </div>
                        <div class="spec">
                            <div class="k">Fuel</div>
                            <div class="v">Petrol</div>
                        </div>
                        <div class="spec">
                            <div class="k">Transmission</div>
                            <div class="v">Manual</div>
                        </div>
                        <div class="spec">
                            <div class="k">Location</div>
                            <div class="v">Mumbai, MH</div>
                        </div>

                       
                    </div>
                </div>
            </aside>

        </div>
    </div>
</section>

@section Scripts {
    <script>
        const input = document.getElementById('chatInput');
        const thread = document.getElementById('chatThread');
        const now = () => new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        function sendMsg() {
            const txt = input.value.trim();
            if (!txt) return;
            const b = document.createElement('div');
            b.className = 'bubble right';
            b.innerHTML = txt + '<div class="t">' + now() + '</div>';
            thread.appendChild(b);
            input.value = '';
            thread.scrollTop = thread.scrollHeight;
        }

        document.getElementById('chatSend').addEventListener('click', sendMsg);
        input.addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });

        function switchChat(btn, name, initial, colorClass) {
            document.querySelectorAll('.chat-item').forEach(i => i.classList.remove('is-active'));
            btn.classList.add('is-active');
            document.getElementById('hdrName').textContent = name;
            const av = document.getElementById('hdrAvatar');
            av.textContent = initial;
            av.className = 'avatar' + (colorClass ? ' ' + colorClass : '');
        }
    </script>
}