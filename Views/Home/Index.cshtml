        <div class="row g-4">

            <!-- 1 -->
            <div class="col-lg-3 col-md-6">
                <div class="wcu-item">
                    <div class="wcu-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1a1008" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                        </svg>
                    </div>
                    <h5 class="wcu-title">Message Sellers Directly</h5>
                    <p class="wcu-text">Talk directly to buyers or sellers inside CarBazaar.<br />Negotiate and close deals with no middlemen.</p>
                </div>
            </div>

            <!-- 2 -->
            <div class="col-lg-3 col-md-6">
                <div class="wcu-item">
                    <div class="wcu-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1a1008" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="1" x2="12" y2="23" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                    </div>
                    <h5 class="wcu-title">Transparent Pricing</h5>
                    <p class="wcu-text">Every listing shows a clear, honest price set by the seller.<br />No hidden fees, no brokerage charges.</p>
                </div>
            </div>

            <!-- 3 -->
            <div class="col-lg-3 col-md-6">
                <div class="wcu-item">
                    <div class="wcu-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1a1008" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99z" />
                            <circle cx="7.5" cy="14.5" r="1.5" />
                            <circle cx="16.5" cy="14.5" r="1.5" />
                        </svg>
                    </div>
                    <h5 class="wcu-title">Post Your Car in Minutes</h5>
                    <p class="wcu-text">Add details, upload photos and go live instantly.<br />Reach 187+ active buyers browsing daily.</p>
                </div>
            </div>

            <!-- 4 -->
            <div class="col-lg-3 col-md-6">
                <div class="wcu-item">
                    <div class="wcu-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1a1008" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.3-4.3" />
                        </svg>
                    </div>
                    <h5 class="wcu-title">Smart Browse & Filter</h5>
                    <p class="wcu-text">Filter by brand, fuel type, year and price range.<br />Find the right car from 247+ listings instantly.</p>
                </div>
            </div>

        </div>
    </div>
    </br></br>
</section>