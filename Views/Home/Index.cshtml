@{
    ViewData["Title"] = "Home";
    var wishlistIds = ViewBag.WishlistCarIds as List<int> ?? new List<int>();
}
<link rel="stylesheet" href="~/css/home-index.css" />

<!-- HERO -->
<section class="home-hero">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <div class="hero-badge-light">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="hero-svg-margin text-orange">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                        </svg>
                        Trusted by 10,000+ buyers
                    </div>
                    <h1 class="hero-title display-4 fw-bold mt-3 mb-3">
                        Find Your <span class="text-orange">Dream Car</span>
                    </h1>
                    <p class="hero-subtitle mb-4 fs-5">
                        Browse thousands of premium vehicles from trusted sellers. Your next car is just a click away.
                    </p>

                    <div class="hero-cta d-flex flex-wrap gap-3 mb-5">
                        <a class="btn btn-warning text-white px-4 py-2 fw-bold hero-btn-primary" asp-controller="Cars" asp-action="Browse">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="hero-svg-margin-8">
                                <circle cx="11" cy="11" r="8" />
                                <path d="m21 21-4.3-4.3" />
                            </svg>
                            Browse Cars
                        </a>
                        <a class="btn btn-outline-dark px-4 py-2 fw-bold hero-btn-secondary" asp-controller="Cars" asp-action="OldBrowse">
                            View All Listings &nbsp;→
                        </a>
                    </div>

                    <div class="hero-perks d-flex flex-wrap gap-4 text-muted small">
                        <div class="d-flex align-items-center gap-2">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="3">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Verified Sellers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="1.5">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                            Quality Guaranteed
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="hero-media-wrapper">
                    <img src="~/images/2721-inset12-2024-maserati-mc20.png" alt="Featured car" class="img-fluid hero-image" />
                    <div class="hero-stat-badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="hero-svg-margin text-orange">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                        </svg>
                        <span class="fw-bold">50+ Cars Listed</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- LATEST LISTINGS -->
<section class="latest-section bg-light-orange">
    <div class="container">

        <div class="section-header d-flex justify-content-between align-items-end mb-4">
            <div>
                <div class="section-kicker text-uppercase fw-bold mb-1">Featured</div>
                <h2 class="fw-bold section-title">Latest Listings</h2>
            </div>
            <a asp-controller="Cars" asp-action="Browse" class="text-decoration-none fw-bold section-link">View All &nbsp;→</a>
        </div>

        <div class="row g-4">
            @if (ViewBag.LatestCars != null)
            {
                foreach (var car in ViewBag.LatestCars as List<CarBazzar.Controllers.ApiCarDto>)
                {
                    <div class="col-md-4">
                        <div class="car-card-new">
                            <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@car.Id" class="wishlist-form-pos">
                                <button type="submit" class="wishlist-btn-new @(wishlistIds.Contains(car.Id) ? "active" : "")">
                                    @if (wishlistIds.Contains(car.Id))
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="#f07500" stroke="#f07500" stroke-width="2">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                        </svg>
                                    }
                                </button>
                            </form>
                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="text-decoration-none">
                                <img src="@Url.Action("GetImage", "Cars", new { id = car.Id })" alt="@car.Title" class="car-img-top" />
                                <div class="car-body-new">
                                    <h5 class="car-title-new">@car.Title</h5>
                                    <div class="car-price-new">₹@car.Price.ToString("N0")</div>
                                    <div class="car-specs-new">
                                        <span>@car.Year</span>
                                        <span class="dot"></span>
                                        <span>@car.Mileage</span>
                                        <span class="dot"></span>
                                        <span>@(string.IsNullOrEmpty(car.FuelType) ? "Gasoline" : car.FuelType)</span>
                                        <span class="dot"></span>
                                        <span>@(string.IsNullOrEmpty(car.Location) ? "Unknown" : car.Location)</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- BROWSE BY TYPE -->
<section class="type-section bg-light-orange">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-kicker text-uppercase fw-bold mb-1">Categories</div>
            <h2 class="fw-bold section-title">Browse by Type</h2>
        </div>

        <div class="row g-4">

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/2721-inset12-2024-maserati-mc20.png" alt="Lamborghini" />
                    <div class="category-overlay">
                        <h5 class="m-0">Lamborghini</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/suv.jpg" alt="SUV" />
                    <div class="category-overlay">
                        <h5 class="m-0">SUV</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/sedan.jpg" alt="Mersedes" />
                    <div class="category-overlay">
                        <h5 class="m-0">Mersedes</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/coupe.jpg" alt="Toyota" />
                    <div class="category-overlay">
                        <h5 class="m-0">Toyota</h5>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- WHY CHOOSE US -->
