@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="home-hero">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <div class="hero-badge small">
                    Trusted by 10,000+ buyers
                </div>
                <h1 class="hero-title display-5 fw-bold mt-3 mb-2">
                    Find Your <span>Dream Car</span>
                </h1>
                <p class="hero-subtitle mb-4">
                    Browse thousands of premium vehicles from trusted sellers. Your next car is just a click away.
                </p>

                <div class="hero-cta d-flex flex-wrap gap-3 mb-4">
                    <a class="btn btn-warning text-white" asp-controller="Cars" asp-action="Browse">
                        Browse Cars
                    </a>
                    <a class="btn btn-outline-warning" asp-controller="Cars" asp-action="OldBrowse">
                        View All Listings
                    </a>
                </div>

                <div class="hero-perks d-flex flex-wrap gap-4 small">
                    <div class="d-flex align-items-center gap-2">
                        <span class="perk-dot"></span>
                        Verified Sellers
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="perk-dot"></span>
                        Quality Guaranteed
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="hero-media">
                    <img src="~/images/2721-inset12-2024-maserati-mc20.png" alt="Featured car" />
                    <div class="hero-counter">
                        <div class="h5 mb-0">50+</div>
                        <div class="small">Cars listed</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- LATEST LISTINGS -->
<section class="latest-section">
    <div class="container">

        <div class="section-header">
            <div>
                <div class="section-kicker">Featured</div>
                <h2>Latest Listings</h2>
            </div>
            <a asp-controller="Cars" asp-action="Browse">View all →</a>
        </div>

        <div class="car-grid">

            <!-- CARD 1 -->
            <div class="car-card">
                <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="1">
                    <button type="submit"
                            class="wishlist-btn @(CarBazzar.Models.WishlistStore.IsSaved(1) ? "is-active" : "")"
                            aria-label="Toggle wishlist"
                            aria-pressed="@(CarBazzar.Models.WishlistStore.IsSaved(1).ToString().ToLowerInvariant())">
                        ♥
                    </button>
                </form>
                <a class="car-card-link" asp-controller="Cars" asp-action="Details" asp-route-id="1">
                    <img src="~/images/coupe.jpg" alt="Toyota Camry 2022" />
                    <div class="car-info">
                        <h6>Toyota Camry 2022</h6>
                        <p>Petrol • Automatic • 12,000 km</p>
                        <span>₹29,50,000</span>
                    </div>
                </a>
            </div>

            <!-- CARD 2 -->
            <div class="car-card">
                <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="2">
                    <button type="submit"
                            class="wishlist-btn @(CarBazzar.Models.WishlistStore.IsSaved(2) ? "is-active" : "")"
                            aria-label="Toggle wishlist"
                            aria-pressed="@(CarBazzar.Models.WishlistStore.IsSaved(2).ToString().ToLowerInvariant())">
                        ♥
                    </button>
                </form>
                <a class="car-card-link" asp-controller="Cars" asp-action="Details" asp-route-id="2">
                    <img src="~/images/images.jpg" alt="Honda Civic 2021" />
                    <div class="car-info">
                        <h6>Honda Civic 2021</h6>
                        <p>Petrol • Manual • 18,000 km</p>
                        <span>₹24,20,000</span>
                    </div>
                </a>
            </div>

            <!-- CARD 3 -->
            <div class="car-card">
                <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="3">
