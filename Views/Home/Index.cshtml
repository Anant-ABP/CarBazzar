@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="hero">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-6">
                <h1 class="hero-title">
                    Find Your <span>Dream Car</span>
                </h1>

                <p class="hero-subtitle">
                    Buy and sell verified used cars with confidence.
                </p>

                <div class="search-box">
                    <input type="text" placeholder="Search brand..." />
                    <select>
                        <option>Select Budget</option>
                        <option>Below ₹5L</option>
                        <option>₹5L - ₹15L</option>
                        <option>Above ₹15L</option>
                    </select>
                    <button>Search</button>
                </div>
            </div>

            <div class="col-lg-6 text-end">
                <img src="~/images/hero-car.svg" class="hero-img" alt="Hero car" />
            </div>

        </div>
    </div>
</section>


<!-- LATEST LISTINGS -->
<section class="latest-section">
    <div class="container">

        <div class="section-header">
            <h2>Latest Listings</h2>
            <a href="#">View All</a>
        </div>

        <div class="car-grid">

            <!-- CARD 1 -->
            <div class="car-card">
                <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="1">
                    <button type="submit"
                            class="wishlist-btn @(CarBazzar.Models.WishlistStore.IsSaved(1) ? "is-active" : "")"
                            aria-label="Toggle wishlist"
                            aria-pressed="@(CarBazzar.Models.WishlistStore.IsSaved(1).ToString().ToLowerInvariant())">
                        ♥
                    </button>
                </form>
                <a class="car-card-link" asp-controller="Cars" asp-action="Details" asp-route-id="1">
                    <img src="~/images/coupe.jpg" alt="Toyota Camry 2022" />
                    <div class="car-info">
                        <h6>Toyota Camry 2022</h6>
                        <p>Petrol • Automatic • 12,000 km</p>
                        <span>₹29,50,000</span>
                    </div>
                </a>
            </div>

            <!-- CARD 2 -->
