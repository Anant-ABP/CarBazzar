@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="home-hero">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <div class="hero-badge-light">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px; color:#f07500">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                        </svg>
                        Trusted by 10,000+ buyers
                    </div>
                    <h1 class="hero-title display-4 fw-bold mt-3 mb-3">
                        Find Your <span style="color:#f07500">Dream Car</span>
                    </h1>
                    <p class="hero-subtitle mb-4 fs-5">
                        Browse thousands of premium vehicles from trusted sellers. Your next car is just a click away.
                    </p>

                    <div class="hero-cta d-flex flex-wrap gap-3 mb-5">
                        <a class="btn btn-warning text-white px-4 py-2 fw-bold" asp-controller="Cars" asp-action="Browse" style="border-radius:10px; background:#f07500; border:none">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:8px">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                            </svg>
                            Browse Cars
                        </a>
                        <a class="btn btn-outline-dark px-4 py-2 fw-bold" asp-controller="Cars" asp-action="OldBrowse" style="border-radius:10px; border:1px solid #eee; background:#fff">
                            View All Listings &nbsp;→
                        </a>
                    </div>

                    <div class="hero-perks d-flex flex-wrap gap-4 text-muted small">
                        <div class="d-flex align-items-center gap-2">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Verified Sellers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="1.5">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                            Quality Guaranteed
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="hero-media-wrapper">
                    <img src="~/images/2721-inset12-2024-maserati-mc20.png" alt="Featured car" class="img-fluid" style="border-radius:24px; box-shadow: 0 20px 60px rgba(0,0,0,0.1)"/>
                    <div class="hero-stat-badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px; color:#f07500">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                        </svg>
                        <span class="fw-bold">50+ Cars Listed</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- LATEST LISTINGS -->
<section class="latest-section" style="background: #fffaf5">
    <div class="container">

        <div class="section-header d-flex justify-content-between align-items-end mb-4">
            <div>
                <div class="section-kicker text-uppercase fw-bold mb-1" style="color:#f07500; font-size:12px; letter-spacing:1px">Featured</div>
                <h2 class="fw-bold" style="color:#1a202c">Latest Listings</h2>
            </div>
            <a asp-controller="Cars" asp-action="Browse" class="text-decoration-none fw-bold" style="color:#f07500">View All &nbsp;→</a>
        </div>

        <div class="row g-4">

            <!-- CARD 1 -->
            <div class="col-md-4">
                <div class="car-card-new">
                    <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="1" class="wishlist-form-pos">
                        <button type="submit" class="wishlist-btn-new @(CarBazzar.Models.WishlistStore.IsSaved(1) ? "active" : "")">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="@(CarBazzar.Models.WishlistStore.IsSaved(1) ? "#f07500" : "none")" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                        </button>
                    </form>
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="1" class="text-decoration-none">
                        <img src="~/images/coupe.jpg" alt="BMW M4" class="car-img-top"/>
                        <div class="car-body-new">
                            <h5 class="car-title-new">2024 BMW M4 Competition</h5>
                            <div class="car-price-new">₹78,900</div>
                            <div class="car-specs-new">
                                <span>2024</span>
                                <span class="dot"></span>
                                <span>3200</span>
                                <span class="dot"></span>
                                <span>Gasoline</span>
                                <span class="dot"></span>
                                <span>Los Angeles, CA</span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- CARD 2 -->
            <div class="col-md-4">
                <div class="car-card-new">
                    <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="2" class="wishlist-form-pos">
                        <button type="submit" class="wishlist-btn-new @(CarBazzar.Models.WishlistStore.IsSaved(2) ? "active" : "")">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="@(CarBazzar.Models.WishlistStore.IsSaved(2) ? "#f07500" : "none")" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                        </button>
                    </form>
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="2" class="text-decoration-none">
                        <img src="~/images/images.jpg" alt="Tesla Model 3" class="car-img-top"/>
                        <div class="car-body-new">
                            <h5 class="car-title-new">2023 Tesla Model 3</h5>
                            <div class="car-price-new">₹42,500</div>
                            <div class="car-specs-new">
                                <span>2023</span>
                                <span class="dot"></span>
                                <span>12800</span>
                                <span class="dot"></span>
                                <span>Electric</span>
                                <span class="dot"></span>
                                <span>San Francisco, CA</span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- CARD 3 -->
            <div class="col-md-4">
                <div class="car-card-new">
                    <form method="post" asp-controller="Wishlist" asp-action="Toggle" asp-route-id="3" class="wishlist-form-pos">
                        <button type="submit" class="wishlist-btn-new @(CarBazzar.Models.WishlistStore.IsSaved(3) ? "active" : "")">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="@(CarBazzar.Models.WishlistStore.IsSaved(3) ? "#f07500" : "none")" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                        </button>
                    </form>
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="3" class="text-decoration-none">
                        <img src="~/images/sedan.jpg" alt="Porsche 911" class="car-img-top"/>
                        <div class="car-body-new">
                            <h5 class="car-title-new">2022 Porsche 911 Carrera S</h5>
                            <div class="car-price-new">₹124,900</div>
                            <div class="car-specs-new">
                                <span>2022</span>
                                <span class="dot"></span>
                                <span>8500</span>
                                <span class="dot"></span>
                                <span>Gasoline</span>
                                <span class="dot"></span>
                                <span>Miami, FL</span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- BROWSE BY TYPE -->
<section class="type-section" style="background: #fffaf5">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-kicker text-uppercase fw-bold mb-1" style="color:#f07500; font-size:12px; letter-spacing:1px">Categories</div>
            <h2 class="fw-bold" style="color:#1a202c">Browse by Type</h2>
        </div>

        <div class="row g-4">

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/2721-inset12-2024-maserati-mc20.png" alt="Lamborghini"/>
                    <div class="category-overlay">
                        <h5 class="m-0">Lamborghini</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/suv.jpg" alt="SUV"/>
                    <div class="category-overlay">
                        <h5 class="m-0">SUV</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/sedan.jpg" alt="Mersedes"/>
                    <div class="category-overlay">
                        <h5 class="m-0">Mersedes</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="category-card-new">
                    <img src="~/images/coupe.jpg" alt="Toyota"/>
                    <div class="category-overlay">
                        <h5 class="m-0">Toyota</h5>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- WHY CHOOSE US -->
<section style="padding: 60px 0 48px; background: #fffaf5;">
    <div class="container">

        <div class="text-center mb-5">
            <div style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:2px; color:#f07500; margin-bottom:8px">Why CarBazzar</div>
            <h2 class="fw-bold" style="color:#1a202c">Buy or Sell with <span style="color:#f07500">Confidence</span></h2>
        </div>

        <div class="row g-4 justify-content-center">

            <div class="col-lg-4 col-md-6">
                <div class="wc-card">
                    <div class="wc-icon-box">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="1.8">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            <polyline points="9 12 11 14 15 10" />
                        </svg>
                    </div>
                    <h5 class="wc-card-title">Verified sellers only</h5>
                    <p class="wc-card-text">Every buyer and seller is identity-checked before listing. Browse 50+ live cars from trusted, verified profiles.</p>
                    <div class="wc-stat-row">
                        <span class="wc-stat">10K+</span>
                        <span class="wc-stat-label">verified users</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="wc-card">
                    <div class="wc-icon-box">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="1.8">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                        </svg>
                    </div>
                    <h5 class="wc-card-title">Chat directly, close fast</h5>
                    <p class="wc-card-text">No middlemen. Message buyers or sellers right on CarBazzar — negotiate and close deals in real time.</p>
                    <div class="wc-stat-row">
                        <span class="wc-stat">&lt;5 min</span>
                        <span class="wc-stat-label">avg. first response</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="wc-card">
                    <div class="wc-icon-box">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f07500" stroke-width="1.8">
                            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                    </div>
                    <h5 class="wc-card-title">List your car in 3 minutes</h5>
                    <p class="wc-card-text">Upload photos, set your price, go live. Reach 50,000+ active buyers browsing CarBazzar right now.</p>
                    <div class="wc-stat-row">
                        <span class="wc-stat">3 min</span>
                        <span class="wc-stat-label">to post a listing</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    .wc-card {
        background: #fff;
        border: 1px solid #ede8e3;
        border-radius: 16px;
        padding: 28px 24px 22px;
        height: 100%;
        position: relative;
        overflow: hidden;
        transition: transform 0.28s cubic-bezier(0.23,1,0.32,1), border-color 0.28s ease, box-shadow 0.28s ease;
    }

        .wc-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(240,117,0,0.06) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.28s ease;
            pointer-events: none;
        }

        .wc-card:hover {
            transform: translateY(-6px);
            border-color: rgba(240,117,0,0.35);
            box-shadow: 0 16px 40px rgba(240,117,0,0.09);
        }

            .wc-card:hover::before {
                opacity: 1;
            }

    .wc-icon-box {
        width: 44px;
        height: 44px;
        background: #fff5eb;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        transition: transform 0.28s ease;
    }

    .wc-card:hover .wc-icon-box {
        transform: scale(1.08) rotate(4deg);
    }

    .wc-card-title {
        font-size: 16px;
        font-weight: 700;
        color: #1a202c;
        margin-bottom: 8px;
        transition: color 0.2s;
    }

    .wc-card:hover .wc-card-title {
        color: #f07500;
    }

    .wc-card-text {
        font-size: 13.5px;
        color: #718096;
        line-height: 1.65;
        margin-bottom: 0;
    }

    .wc-stat-row {
        display: flex;
        align-items: baseline;
        gap: 6px;
        padding-top: 14px;
        margin-top: 16px;
        border-top: 1px solid #f0ece7;
    }

    .wc-stat {
        font-size: 18px;
        font-weight: 800;
        color: #f07500;
    }

    .wc-stat-label {
        font-size: 12px;
        color: #a0aec0;
    }
</style>


<style>
    .hero-badge-light {
        display: inline-flex;
        align-items: center;
        padding: 6px 16px;
        background: #fff5eb;
        color: #8a5e3b;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 600;
    }

    .hero-stat-badge {
        position: absolute;
        top: 24px;
        left: 24px;
        background: #fff;
        padding: 10px 18px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        font-size: 14px;
        color: #1a202c;
    }

    .hero-media-wrapper {
        position: relative;
    }

    /* New Car Card Styles */
    .car-card-new {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        position: relative;
        transition: transform 0.3s ease;
    }
    .car-card-new:hover {
        transform: translateY(-8px);
    }
    .car-img-top {
        width: 100%;
        height: 240px;
        object-fit: cover;
    }
    .car-body-new {
        padding: 20px;
    }
    .car-title-new {
        font-size: 18px;
        font-weight: 700;
        color: #1a202c;
        margin-bottom: 8px;
    }
    .car-price-new {
        font-size: 24px;
        font-weight: 800;
        color: #f07500;
        margin-bottom: 12px;
    }
    .car-specs-new {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        font-size: 13px;
        color: #718096;
    }
    .car-specs-new .dot {
        width: 4px;
        height: 4px;
        background: #cbd5e0;
        border-radius: 50%;
    }
    .wishlist-form-pos {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 2;
    }
    .wishlist-btn-new {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #718096;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: all 0.2s;
    }
    .wishlist-btn-new:hover {
        transform: scale(1.1);
    }
    .wishlist-btn-new.active {
        color: #f07500;
    }

    /* Category Card Styles */
    .category-card-new {
        position: relative;
        height: 200px;
        border-radius: 16px;
        overflow: hidden;
        cursor: pointer;
    }
    .category-card-new img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .category-card-new:hover img {
        transform: scale(1.1);
    }
    .category-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(transparent 50%, rgba(0,0,0,0.8));
        display: flex;
        align-items: flex-end;
        padding: 20px;
        color: #fff;
    }
</style>