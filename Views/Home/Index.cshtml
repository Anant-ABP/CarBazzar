        </div>
    </div>
</section>


<!-- BROWSE BY TYPE -->
<section class="type-section">
    <div class="container">
        <h2 class="text-center mb-5">Browse by Type</h2>

        <div class="type-grid">

            <div class="type-card">
                <img src="~/images/suv.jpg" alt="SUV" />
                <h6>SUV</h6>
            </div>

            <div class="type-card">
                <img src="~/images/sedan.jpg" alt="Sedan" />
                <h6>Sedan</h6>
            </div>

            <div class="type-card">
                <img src="~/images/coupe.jpg" alt="Coupe" />
                <h6>Coupe</h6>
            </div>

            <div class="type-card">
                <img src="~/images/truc.jpg" alt="Hatchback" />
                <h6>Hatchback</h6>
            </div>

        </div>
    </div>
</section>