                        ♥
                    </button>
                </form>
                <a class="car-card-link" asp-controller="Cars" asp-action="Details" asp-route-id="3">
                    <img src="~/images/sedan.jpg" alt="BMW 3 Series" />
                    <div class="car-info">
                        <h6>BMW 3 Series</h6>
                        <p>Diesel • Automatic • 9,000 km</p>
                        <span>₹42,00,000</span>
                    </div>
